\documentclass[fontsize=14pt,DIV=calc]{leadsheet}
\usepackage{MyLeadsheets}

\begin{document}

% Transposed wrapper -- transcribed in C, performed up a whole step in D, so
% `transpose=2'. A literal amount is fine now (the old \SongTranspose macro
% indirection is gone): the original-key sibling is just a separate wrapper,
% TransposeDemo-OriginalKey.song, that omits transpose=. Both \input the shared
% body TransposeDemo--input.song.
%
% NB key label: the title template prints key={C} raw, so this transposed sheet
% still shows "C" though its chords sound in D -- key-label-follows-transpose is
% deferred (see NOTES.md). See CLAUDE.md "Output views and arrangements".
\begin{song}[transpose=2]{title={Transpose Demo}, key={C}}
  \input{TransposeDemo--input.song}
\end{song}

\end{document}
