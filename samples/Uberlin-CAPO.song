\documentclass[fontsize=14pt,DIV=calc]{leadsheet}
\usepackage{MyLeadsheets}

\begin{document}

% Capo wrapper -- `capo=3' makes leadsheets render the capo shapes (chords down
% 3) and the title template add a "capo 3" note. Shares the body with the
% concert wrapper Uberlin.song via \input{UberlinDemo--input.song}. The
% displayed key stays concert pitch (Gm). See CLAUDE.md "Output views and arrangements".
\begin{song}[]{title={Uberlin}, band={REM}, key={Gm}, capo=3}
  \input{UberlinDemo--input.song}
\end{song}

\end{document}
