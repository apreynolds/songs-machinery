#!/usr/bin/env bash
# build-pdfs — compile .song files into their default song-sheet PDFs
# Usage: build-pdfs [SONG.song ...]
#
# With no arguments, compiles every *.song file in the current directory.
# For each source it produces SONG.pdf alongside the source (the default
# lyrics+chords sheet). Auxiliary files are sent to a per-project dir under
# ~/.cache/latexmk/, matching the aux_dir scheme used by vimtex (see the note
# by the latexmk call).
#
# Views via magic comments: a leading comment block in the .song file can
# request extra PDFs, e.g.
#
#     %! views: chords, lyrics
#
# Each listed view produces SONG--<view>.pdf, built by injecting
# \def\View{<view>} so MyLeadsheets.sty selects that view's bodies: the
# chords view prints the chart twins and suppresses the lyric verse types; the
# lyrics view prints the lyric verse bodies with the chords stripped
# (print-chords=false); the debug view prints BOTH families in one sheet (lyric
# bodies and their chart twins) for proofing line lengths/spacing; the phone view
# prints the same full lyric+chord body on tall long-paper geometry at a larger
# base font, for reading one song as a continuous scroll on a phone. An
# orthogonal `-gray' modifier prints any content view with all colour switched
# off (black text, white section boxes) for plain printing: `chords-gray',
# `lyrics-gray', and `full-gray' (a friendlier spelling of bare `gray', both =
# full content). `full-gray'/`gray' both yield Song--gray.pdf. `chords',
# `lyrics', `debug', `phone' and the `-gray' variants are all wired up (see
# compile_view()).
# The magic comment must sit in the leading comment block,
# before \documentclass (TeX magic-comment convention).
#
# Different pitches/keys of one song (capo shapes vs concert, or a real key
# change) are NOT a magic-comment axis: each is its own wrapper .song that
# \input's a shared body file. Put the song body (no preamble) in
# SONG--input.song, then write thin wrappers -- SONG.song, SONG-CAPO.song,
# SONG-OriginalKey.song, ... -- that each set their own \begin{song}[...]{...}
# options (capo=N, transpose=N, key=...) and \input{SONG--input.song}. Every
# wrapper is a normal standalone .song and builds to one PDF here. The
# -CAPO/-OriginalKey suffix (single hyphen) marks different musical content, vs
# --chords/--lyrics (double hyphen) presentation; it is now just your filename,
# not something this script generates.
#
# Body files (SONG--input.song) are includes, not standalone documents, so this
# script SKIPS any *--input.song (it has no preamble and would fail to compile).
#
# Output directory via an OUTDIR file: if the song's own directory contains a
# file named OUTDIR (or .OUTDIR), a directory path on its own line (a leading ~
# is expanded) redirects PDFs for songs in that directory there instead of
# alongside the source. By default the build goes straight to that directory
# (no local copy); add a line reading BOTH (or COPY) to instead build locally
# AND copy the PDFs to the destination, keeping both. Blank and #-comment lines
# are ignored and the path / keyword may appear in either order, e.g.
#
#     BOTH
#     ~/Dropbox/songsheets
#
# OUTDIR is consulted per song directory, so a multi-file/multi-directory
# invocation can ship each song's PDFs to a different place. The file is meant
# to be git-ignored, so the destination stays a local choice. If neither file
# exists -- or the named path is missing or not a directory -- the build falls
# back to the usual local output (a bad path warns). OUTDIR takes precedence
# over .OUTDIR if both exist.
#
# Relies on the global latexmkrc for the pdflatex invocation (--shell-escape,
# nonstopmode) and on TEXINPUTS for the PR#46-shadowed leadsheets file. How that
# repo's .sty/.tex shadow the texlive copies depends on deployment: a standalone
# checkout is found via the shell's recursive ~/repos TEXINPUTS tree; a
# .machinery submodule is found via the parent project's .latexmkrc, which
# prepends .machinery// to TEXINPUTS.

set -uo pipefail

usage() {
  # Print the header block (everything after the shebang, up to the first
  # blank-ish line) so -h stays in sync with the comment above.
  sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
}

case "${1:-}" in
  -h | --help)
    usage
    exit 0
    ;;
esac

# Read requested views from a .song file's leading magic-comment block.
# Recognises lines of the form `%! views: a, b, c` (flexible spacing) and
# echoes one view token per line. Scanning stops at the first line that is
# neither blank nor a `%` comment, so only the leading block is consulted.
read_views() {
  local file=$1 line val tok
  while IFS= read -r line; do
    # First real (non-blank, non-comment) line ends the magic-comment block.
    if [[ -n $line && ${line#\%} == "$line" ]]; then
      break
    fi
    if [[ $line =~ ^%![[:space:]]*views[[:space:]]*:[[:space:]]*(.*)$ ]]; then
      val=${BASH_REMATCH[1]}
      IFS=',' read -ra toks <<<"$val"
      for tok in "${toks[@]}"; do
        # Trim surrounding whitespace.
        tok=${tok#"${tok%%[![:space:]]*}"}
        tok=${tok%"${tok##*[![:space:]]}"}
        [[ -n $tok ]] && printf '%s\n' "$tok"
      done
    fi
  done <"$file"
}

# Resolve an alternate output directory from an OUTDIR / .OUTDIR file in the
# current directory (the song's own directory, since build_song cd's there).
# The file holds a directory path (a leading ~ is expanded) plus an optional
# mode keyword on its own line: BOTH (synonym COPY) means build locally AND copy
# the PDFs to the destination; with no keyword the build goes straight to the
# destination (no local copy). Blank lines and #-comment lines are ignored, and
# the path / keyword may appear in either order. On success echoes two lines --
# the mode (MOVE or BOTH) then the validated path; echoes nothing when the
# caller should build locally: neither file present, no usable path, or a path
# that is missing / not a directory (the last two warn). OUTDIR wins over
# .OUTDIR if both exist.
read_outdir() {
  local f line trimmed lower path="" mode="MOVE"
  for f in OUTDIR .OUTDIR; do
    [[ -f $f ]] && break
  done
  [[ -f $f ]] || return 0          # neither file exists -> build locally

  while IFS= read -r line || [[ -n $line ]]; do
    # Trim surrounding whitespace (covers a trailing CR too).
    trimmed=${line#"${line%%[![:space:]]*}"}
    trimmed=${trimmed%"${trimmed##*[![:space:]]}"}
    [[ -z $trimmed || ${trimmed:0:1} == "#" ]] && continue   # blank / comment
    lower=${trimmed,,}
    case $lower in
      both | copy) mode="BOTH"; continue ;;   # keep a local copy too
    esac
    [[ -z $path ]] && path=$trimmed           # first non-keyword line = path
  done <"$f"

  if [[ -z $path ]]; then
    echo "build-pdfs: $f has no directory path, building locally" >&2
    return 0
  fi
  path=${path/#\~/$HOME}            # expand a leading ~
  if [[ ! -d $path ]]; then
    echo "build-pdfs: $f path '$path' is not a directory, building locally" >&2
    return 0
  fi
  printf '%s\n%s\n' "$mode" "$path"
}

# Build a presentation view (chords, lyrics, debug, phone, or any `-gray'
# variant) of a song: inject \def\View{NAME} so MyLeadsheets.sty selects that
# view's bodies (chords prints the chart twins and suppresses the lyric types;
# lyrics prints the lyric bodies with chords stripped; debug prints both families;
# phone prints the full lyric+chord body on tall long-paper geometry at a larger
# font; a `-gray' view prints its base content with colour switched off). Output
# is SONG--NAME.pdf (NAME already normalised by the caller, e.g. full-gray->gray).
# Forced with -g (the
# source is unchanged, so latexmk's up-to-date check would otherwise skip the
# rebuild). The -pdflatex override mirrors the global latexmkrc invocation, with
# the view name interpolated into the injected \def (hence double quotes and
# escaped backslashes, unlike the fixed-\def helpers above).
compile_view() {
  local jobname=$1 src=$2 auxdir=$3 view=$4 outdir=$5
  latexmk -pdf -g -auxdir="$auxdir" ${outdir:+"-outdir=$outdir"} -jobname="$jobname--$view" \
    -pdflatex="pdflatex --shell-escape %O -synctex=0 -interaction=nonstopmode \"\\def\\View{$view} \\input{%S}\"" \
    "$src"
}

# Build the default PDF for one .song file, then any magic-comment views.
# Runs in a subshell so the cd (and the aux-dir scheme that depends on cwd)
# stays local to this build. Returns non-zero if the default compile fails.
build_song() {
  local song=$1 dir base jobname auxdir view varaux outinfo outdir outmode movedir
  dir=$(dirname -- "$song")
  base=$(basename -- "$song")
  jobname=${base%.song}

  (
    # Compile in the source's own directory so the PDF lands next to the
    # source (latexmk's out-dir defaults to cwd, and only -auxdir is set).
    # Auxiliary files go to a per-project dir under ~/.cache/latexmk/,
    # replicating the aux_dir scheme in ~/.config/vim/custom/vimtex.vim
    # ({parent-dir}-{jobname}) so this script and vimtex share one
    # incremental-build database. The aux files are git-ignored scratch;
    # keeping them lets latexmk skip unchanged rebuilds.
    cd "$dir" || exit
    auxdir="$HOME/.cache/latexmk/${PWD##*/}-$jobname"
    mkdir -p "$auxdir" || exit

    # Output directory: an OUTDIR/.OUTDIR file here can redirect PDFs elsewhere
    # (see header). read_outdir echoes two lines (mode, path) or nothing.
    # MOVE (default): latexmk's -outdir writes the PDF straight to the
    # destination. BOTH: build locally as usual (out-dir defaults to cwd), then
    # copy each PDF to the destination. movedir carries the -outdir path for the
    # MOVE case only, so the BOTH case keeps its local build.
    outdir=""; outmode=""; movedir=""
    if outinfo=$(read_outdir) && [[ -n $outinfo ]]; then
      outmode=${outinfo%%$'\n'*}
      outdir=${outinfo#*$'\n'}
      if [[ $outmode == BOTH ]]; then
        echo "    -> outdir: $outdir (local copy kept)"
      else
        movedir="$outdir"
        echo "    -> outdir: $outdir"
      fi
    fi

    # The default PDF. Capo / transposed / original-key sheets are no longer
    # built here: each is its own wrapper .song (see header) and arrives as a
    # separate $song in the loop below.
    latexmk -pdf -auxdir="$auxdir" ${movedir:+"-outdir=$movedir"} "$base" || exit
    echo "    ok: $jobname.pdf"
    if [[ $outmode == BOTH ]]; then
      cp -- "$jobname.pdf" "$outdir/" || exit
    fi

    for view in $(read_views "$base"); do
      # `full-gray' is just a friendlier magic-comment spelling of the bare
      # `gray' view (full content, colour off); normalise it so the PDF lands at
      # Song--gray.pdf, not Song--full-gray.pdf. The other gray variants
      # (chords-gray, lyrics-gray) keep their name as the filename suffix.
      [[ $view == full-gray ]] && view=gray
      case $view in
        chords | lyrics | debug | phone | gray | chords-gray | lyrics-gray)
          varaux="$HOME/.cache/latexmk/${PWD##*/}-$jobname--$view"
          mkdir -p "$varaux" || exit
          compile_view "$jobname" "$base" "$varaux" "$view" "$movedir" || exit
          echo "    + $jobname--$view.pdf ($view)"
          if [[ $outmode == BOTH ]]; then cp -- "$jobname--$view.pdf" "$outdir/" || exit; fi
          ;;
        *)
          echo "build-pdfs: view '$view' not yet supported, skipping" >&2
          ;;
      esac
    done
  )
}

# Collect the songs to build: explicit arguments, or every *.song in cwd.
if [[ $# -gt 0 ]]; then
  songs=("$@")
else
  shopt -s nullglob
  songs=(*.song)
  shopt -u nullglob
fi

if [[ ${#songs[@]} -eq 0 ]]; then
  echo "build-pdfs: no .song files found" >&2
  exit 1
fi

failed=()

for song in "${songs[@]}"; do
  if [[ ! -f $song ]]; then
    echo "build-pdfs: skipping '$song' (not a file)" >&2
    failed+=("$song")
    continue
  fi

  # Shared body includes are not standalone documents (no preamble); a wrapper
  # \input's them. Skip them silently (not a failure) -- they reach here from
  # the bare *.song glob, or if listed explicitly by mistake.
  if [[ $song == *--input.song ]]; then
    echo "build-pdfs: skipping '$song' (shared body include)"
    continue
  fi

  echo "==> $song"
  if ! build_song "$song"; then
    echo "build-pdfs: FAILED on '$song'" >&2
    failed+=("$song")
  fi
done

if [[ ${#failed[@]} -gt 0 ]]; then
  echo "build-pdfs: ${#failed[@]} of ${#songs[@]} failed: ${failed[*]}" >&2
  exit 1
fi
