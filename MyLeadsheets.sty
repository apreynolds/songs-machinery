\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{MyLeadsheets}

\def\normalbarwidth{.09em}

\RequirePackage[T1]{fontenc}
\RequirePackage[defaultsans]{lato}
\RequirePackage[scale=0.96]{newtxtt}

% Make the document body sans by default so .song files need no \sffamily after
% \begin{document}.  lato's [defaultsans] sets Lato as the *sans* family but
% leaves \familydefault at the roman family; repointing it at \sfdefault is the
% standard LaTeX route (newtxtt still supplies \ttfamily, used by chords/measures).
\renewcommand*\familydefault{\sfdefault}

\newcommand\MyMargin{0.3cm}
\RequirePackage[margin=\MyMargin,letterpaper]{geometry}

% ---------------------------------------------------------------------------
% Extra song-part types
% ---------------------------------------------------------------------------
% Part types beyond the package/class defaults, used across the song corpus.
% \newversetype is the documented command for defining a verse-like environment;
% their names, colours and templates are configured below alongside the built-in
% types.  (prechorus is already provided by the leadsheet class, so it only needs
% naming/colouring, not defining here.)
\newversetype{lift}
\newversetype{postchorus}
\newversetype{custompart}   % generic catch-all section (was "mypart" in the reference)

% ---------------------------------------------------------------------------
% Coloured song-section boxes  (approach B, plain-LaTeX style)
% ---------------------------------------------------------------------------
% Each leadsheets part type (verse, chorus, ...) gets its own tcolorbox-based
% "template".  Templates are the package's documented extension point
% (\defineversetypetemplate, manual section "verse-type templates").  Writing
% \begin{verse} ... \end{verse} in the .song file then wraps the section in
% its coloured box -- no outer wrapper environment is needed.
%
% Everything here uses the package's *documented* template commands
% (\verselabel, \ifobeylines, \setleadsheets), patterned on the manual's own
% "itemize" template, so no LaTeX3 (expl3) syntax is needed at all.
\RequirePackage[dvipsnames]{xcolor}
\RequirePackage{tcolorbox}

% --- shared box body -------------------------------------------------------
% The colour (#1) is the only thing that varies between part types.  The rest
% reproduces the package's built-in "itemize" template so the section label
% \verselabel keeps its normal placement; we only add the tcolorbox around it.
% \makeatletter is needed solely for \@itemdepth, a standard LaTeX list
% internal -- exactly as the manual's own itemize example uses it.
\makeatletter
\newcommand\myleadsheetsboxbegin[1]{%
  \tcolorbox[left=0pt,right=0pt,boxrule=0mm,arc=0mm,colback=#1]%
  \itemize
  \@itemdepth=0
  \ifobeylines
    {\setlength{\parskip}{0pt}\setleadsheets{obey-lines-parskip=\parsep}}%
    {}%
  \item[{\verselabel}]%
}
\makeatother
\newcommand\myleadsheetsboxend{\enditemize\endtcolorbox}

% --- one template per part type, colour written in directly ----------------
% These are not applied automatically; opt in per section by passing the
% matching template in the .song file, e.g. \begin{verse}[template=versebox].
\defineversetypetemplate{versebox}     {\myleadsheetsboxbegin{Gray!6}}        {\myleadsheetsboxend}
\defineversetypetemplate{chorusbox}    {\myleadsheetsboxbegin{Green!9}}       {\myleadsheetsboxend}
\defineversetypetemplate{solobox}      {\myleadsheetsboxbegin{RoyalPurple!14}}{\myleadsheetsboxend}
\defineversetypetemplate{introbox}     {\myleadsheetsboxbegin{Dandelion!10}}  {\myleadsheetsboxend}
\defineversetypetemplate{outrobox}     {\myleadsheetsboxbegin{Dandelion!10}}  {\myleadsheetsboxend}
\defineversetypetemplate{interludebox} {\myleadsheetsboxbegin{Dandelion!15}}  {\myleadsheetsboxend}
\defineversetypetemplate{bridgebox}    {\myleadsheetsboxbegin{RoyalBlue!14}}  {\myleadsheetsboxend}
\defineversetypetemplate{liftbox}      {\myleadsheetsboxbegin{Green!5}}       {\myleadsheetsboxend}
\defineversetypetemplate{prechorusbox} {\myleadsheetsboxbegin{Green!5}}       {\myleadsheetsboxend}
\defineversetypetemplate{postchorusbox}{\myleadsheetsboxbegin{Green!5}}       {\myleadsheetsboxend}
\defineversetypetemplate{custompartbox}{\myleadsheetsboxbegin{white}}         {\myleadsheetsboxend} % untinted

% ---------------------------------------------------------------------------
% Section labels: short names, numbered where appropriate
% ---------------------------------------------------------------------------
% Recurring sections auto-number with a compact one-letter prefix (V1:, C1:,
% ...) from a bare \begin{verse} / \begin{chorus}; one-off sections show a short
% name (In:, S:, Out:).  Every label ends in ":" and is set in the normal
% (non-bold) weight.  All documented: the options go through \setleadsheets, and
% the prefixes come from standard LaTeX counter formatting
% (\renewcommand\the<counter>, which also drops the default trailing ".").
% Override any single section in the .song file with, e.g.,
%   \begin{verse}[named=true,numbered=false,name=Pre-chorus]
% (handy for repeats or out-of-sequence labels, which auto-numbering can't do).

% Recurring, auto-numbered: number plus the ":" separator (e.g. V1:).
\setleadsheets{
  verse/named=false,   verse/numbered=true,   verse/after-label=: ,
  chorus/named=false,  chorus/numbered=true,  chorus/after-label=: ,
}
\renewcommand\theverse{V\arabic{verse}}
\renewcommand\thechorus{C\arabic{chorus}}

% Default extra line spacing inside song sections, so a bare "\\" gives a
% comfortable gap -- no need for \\[1ex] on every line.  A bare \\ now spans
% baselineskip + \mysonglinesep; \\[<len>] still adds <len> more on a specific
% break.  Tune \mysonglinesep to change the default everywhere.
\newlength\mysonglinesep
\setlength\mysonglinesep{1ex}

% Section body text in bold (matches the reference); labels are kept un-bold via
% verses-label-format=\mdseries, overriding the class default of \bfseries
% (leadsheet.cls:145).  \openup widens the interline spacing (see \mysonglinesep
% above) without pushing chords off their lyrics.  chorus needs its own line:
% the class sets a per-type chorus/format=\itshape (leadsheet.cls:147) that
% shadows the global verses-format, so re-assert \bfseries there for bold *and*
% keep its (desired) italic.  (The class italicises info/format the same way.)
\setleadsheets{
  verses-format       = {\bfseries\openup\mysonglinesep} ,
  verses-label-format = \mdseries ,
  chorus/format       = {\bfseries\itshape\openup\mysonglinesep} ,
}

% One-off, named (not numbered; all use the default ":" separator).  Short
% abbreviations taken from the reference; adjust to taste.  custompart is meant
% to be overridden per section with [name=...], "Part" is just its fallback.
\setleadsheets{
  intro/name=In ,
  solo/name=S ,
  outro/name=Out ,
  bridge/name=Br ,
  interlude/name=I/L ,
  prechorus/name=Pr ,
  postchorus/name=Po ,
  lift/name=L ,
  custompart/name=Part ,
}

% ---------------------------------------------------------------------------
% Chords: brick-red, bold, sans
% ---------------------------------------------------------------------------
% chords/format is the documented chord-formatting hook (manual: the "chords/"
% options).  Specifying the whole font -- not just the colour -- keeps chords
% bold sans regardless of the surrounding section format (e.g. they stay sans
% in the italic chorus, though they inherit its slant, as in the reference).
% align-chords=l left-aligns each chord to the start of the word it sits over
% (the package default is centred); this matches the reference.
\setleadsheets{
  chords/format = {\sffamily\normalsize\bfseries\color{BrickRed}} ,
  align-chords  = l ,
}

% ---------------------------------------------------------------------------
% Inline markers
% ---------------------------------------------------------------------------
% Small TikZ/boxed glyphs dropped inline in a lyric or \measures line.  They
% depend only on packages already loaded above (TikZ via tcolorbox, colours via
% xcolor); \leadinto additionally pulls in TikZ's arrows.meta library (loaded at
% its definition), but still no extra \RequirePackage.
%
%   \notebox{<text>} -- boxed performance note, e.g. \notebox{pause}.  LOAD-
%       BEARING: the capo header label (\notebox{capo N}, title template below)
%       uses it; also used directly in several .song files.  Kept.
%   \repeatbar       -- TikZ-drawn repeat glyph (two dots + a slash), used as
%       $\repeatbar$ in legacy raw-pipe .song files.  Ported from the reference
%       .sty so those files compile.  Whether repeat marks should instead live
%       in the \measures builder is a separate, still-open question (CLAUDE.md);
%       porting the glyph here does not pre-empt it.  Kept.
%   \mydot           -- small brick-red beat dot, e.g. ^{\mydot}.  DEPRECATED:
%       kept only so legacy archive .song files keep compiling.  Emits a ONE-
%       time-per-document deprecation warning (see \MyLSmydotwarning).  A clean
%       (converted) song never triggers it, so the no-warnings goal is intact
%       for current work; convert legacy \mydot uses to \measures and drop this.
%   \leadinto{WORD}  -- sets WORD as a "pickup" lead-in to the next section:
%       a short, thick right-arrow on each side, WORD itself italic, slightly
%       smaller, and faux-slanted a touch beyond italic.  Replaces the kernel
%       $\rightarrow$ (thin, curved) and folds the old
%       \leadinto\emph{WORD}\leadinto idiom into one argument-taking command so
%       the styling lives in one place.  Plain text (no math mode).
% \noteboxcolor is the single retune point for both the frame and the text
% colour (matches \minmeasure/\measurepad as tunable knobs).  \fboxsep is set
% locally so the padding is deterministic, not inherited from the ambient
% \fboxsep; \raisebox's box group scopes the assignment, so it reverts on exit.
% The 0.1em lift nudges the box onto the surrounding text baseline.
\newcommand\noteboxcolor{RoyalBlue}
\newcommand\notebox[1]{%
  \raisebox{0.1em}{%
    \setlength\fboxsep{2pt}%
    \fcolorbox{\noteboxcolor}{White}{%
      \bfseries\ttfamily\upshape\textcolor{\noteboxcolor}{#1}%
    }%
  }%
}
\newcommand\note[1]{%
  {\bfseries\ttfamily \textcolor{RoyalBlue}{[#1]}}
}

% \ssp / \bsp: manual horizontal nudge-spacers for fine-tuning spacing inside
% \measures (or anywhere inline).  The *amounts* live in length registers so a
% .song body can retune them with \setlength\ssplength{4pt} (repeatable, and local
% to a TeX group such as a section), without redefining the spacer macro.  Uses
% \hspace* so an explicit nudge is never silently discarded at a line break.
\newlength\ssplength  \setlength\ssplength{8pt}    % small space
\newlength\msplength  \setlength\msplength{16pt}   % medium space
\newlength\bsplength  \setlength\bsplength{24pt}   % big space
\newlength\xsplength  \setlength\xsplength{32pt}   % xl space
\newcommand\ssp{\hspace*{\ssplength}}
\newcommand\msp{\hspace*{\msplength}}
\newcommand\bsp{\hspace*{\bsplength}}
\newcommand\xsp{\hspace*{\xsplength}}

\newcommand\repeatbar{%
  \begin{tikzpicture}[baseline=0ex]
    \draw (0,0) ;
    \filldraw[BrickRed] (0.2,0.3) circle (1.5pt) ;
    \draw[line width=2pt,BrickRed] (0.2,-0.05) -- (0.6,0.38) ;
    \filldraw[BrickRed] (0.6,0.04) circle (1.5pt) ;
  \end{tikzpicture}%
}
% \MyLSmydotwarning fires \PackageWarning once, then \global\let-s itself to
% \relax so the log gets a single line, not one per use (the archive has 1000+
% \mydot uses).  \protect keeps the control sequences literal in the message.
\newcommand\MyLSmydotwarning{%
  \PackageWarning{MyLeadsheets}{%
    \protect\mydot\space is deprecated; convert legacy songs to \protect\measures}%
  \global\let\MyLSmydotwarning\relax
}
\newcommand\mydot{%
  \MyLSmydotwarning
  \begin{tikzpicture}
    \draw (0,0) ;
    \filldraw[BrickRed] (0,0.12) circle (0.9pt) ;
  \end{tikzpicture}%
}

% \leadinto{WORD} is built from two pieces, both reusing already-loaded TikZ.
%
% \MyLSleadarrow -- one short, thick shaft with a filled triangular head (Latex
%   tip, from arrows.meta; \usetikzlibrary is idempotent and may sit anywhere in
%   the preamble, so it lives next to its only user).  baseline=-0.5ex drops the
%   shaft onto the text's math axis so it centres on the line.  Drawn once, used
%   on both sides, both pointing right ("leads into / continues").
%
% The word is set in a one-node picture so it can be faux-slanted past italic:
%   xslant shears the glyphs by x' = x + slant*y.  It MUST be applied as a
%   coordinate transformation (xslant + transform shape), NOT as a canvas
%   transformation (transform canvas={xslant=...}): canvas transforms are
%   invisible to TikZ's bounding-box computation, which collapses the picture to
%   ZERO width so the two arrows close over the word.  As a coordinate transform
%   the sheared box is measured normally (a hair wider than upright), so the word
%   occupies its space.  The shear fixes the y=0 line and the node's base sits at
%   y=0, so the text baseline is untouched and the word still sits on the line --
%   only the ascenders/descenders lean.  The node inherits the ambient weight
%   (bold in song sections), so \itshape gives bold-italic and \small shrinks it.
%
% Knobs: \MyLSleadarrowlen (shaft length), the line width / tip size below, and
% \MyLSleadslant (extra slant; set to 0 for plain italic).
\usetikzlibrary{arrows.meta}
\newlength\MyLSleadarrowlen
\setlength\MyLSleadarrowlen{0.6em}
\newcommand\MyLSleadslant{0.18}
\newcommand\MyLSleadarrow{%
  \begin{tikzpicture}[baseline=-0.5ex]
    \draw[line width=1.3pt,-{Latex[length=3.5pt,width=4.5pt]}]
      (0,0) -- (\MyLSleadarrowlen,0) ;
  \end{tikzpicture}%
}
\newcommand\leadinto[1]{%
  \MyLSleadarrow%
  \begin{tikzpicture}[baseline=(w.base)]
    \node[inner sep=0pt,anchor=base,transform shape,xslant=\MyLSleadslant]
      (w) at (0,0) {\small\itshape #1} ;
  \end{tikzpicture}%
  \MyLSleadarrow
}

% ---------------------------------------------------------------------------
% Difficulty ratings
% ---------------------------------------------------------------------------
% A song carries an optional difficulty glyph via the custom song property
% `difficulty`, written by the author as one of the three symbol macros below,
% e.g. \begin{song}[]{title=..., difficulty={\moderate}}.  The glyph prints as a
% leading marker in the title header (see the title template).
%
% These are drawn in TikZ (already loaded via tcolorbox) rather than set as
% amssymb math glyphs (\bullet/\blacktriangle/\blacklozenge): song sheets do no
% mathematical typesetting, so pulling in amssymb just for three shapes is
% avoidable weight.  (The only other "math" symbols a song uses -- \rightarrow,
% \Uparrow -- are LaTeX-kernel symbols that need no amssymb either, so dropping
% it costs nothing.)  This also matches the existing inline markers (\repeatbar,
% \mydot), which are likewise hand-drawn TikZ.
%
% \MyLSdifficultysize is the single size knob (glyph height); each shape is drawn
% in a unit box scaled by it (x/y = that length), so coordinates read as
% fractions of the glyph size.  baseline=-0.5ex sits the picture's y=0 near the
% text's math axis, vertically centring the glyph on the title.  Colours: easy =
% ForestGreen, moderate = RoyalBlue (dvipsnames); difficult stays black for
% contrast, as in the reference.
\newlength\MyLSdifficultysize
\setlength\MyLSdifficultysize{0.78em}
\newcommand\MyLSdifficultyglyph[2]{% #1 = colour, #2 = fill path in the unit box
  \begin{tikzpicture}[baseline=-0.5ex,x=\MyLSdifficultysize,y=\MyLSdifficultysize]
    \fill[#1] #2 ;
  \end{tikzpicture}%
}
\newcommand\easy     {\MyLSdifficultyglyph{ForestGreen}{(0,0) circle (0.5)}}
\newcommand\moderate {\MyLSdifficultyglyph{RoyalBlue}{(0,0.5) -- (-0.45,-0.35) -- (0.45,-0.35) -- cycle}}
\newcommand\difficult{\MyLSdifficultyglyph{black}{(0,0.5) -- (0.4,0) -- (0,-0.5) -- (-0.4,0) -- cycle}}

% `difficulty' and `tuning' are not leadsheets built-ins (unlike title/band/tempo/key/capo),
% so both must be registered with \definesongproperty before \songproperty{...} /
% \ifsongproperty{...} work in the header template.
\definesongproperty{difficulty}
\definesongproperty{tuning}

% ---------------------------------------------------------------------------
% Measures: minimum bar spacing
% ---------------------------------------------------------------------------
% leadsheets' bar "|" is just an inline rule; the span between two bars has no
% width of its own, so sparse measures (a lone chord) collapse to nothing.
% \measures typesets one music line as a list of measures, each set in a
% left-aligned box of at least \minmeasure -- so barlines never sit closer than
% that, while lyric-heavy measures keep their (larger) natural width.
%
%   \measures{ {m1}{m2}{m3} }       ->  normal bars   | m1 | m2 | m3 |
%   \measures[repeat]{ {m1}{m2} }   ->  repeat bars   |: m1 | m2 :|
%   \measures[final]{ {m1}{m2} }    ->  final bar     | m1 | m2 |||
%
% The .song stays clean -- one braced group per measure -- and the iteration
% lives here.  expl3 is deliberate: \tl_map_inline:nn maps cleanly over brace
% groups (each measure is one list item), which plain LaTeX does only awkwardly.
% Bar styles go through \str_case so adding \doublebar etc. is a one-line edit.
%
% The literal space + \unskip inside the box is load-bearing: the chord splitter
% (\__leadsheets_set_chord:nwn) scans forward to a space to find the lyric a
% chord sits over, so a measure ending "^{Em}LOVE" needs a trailing space to
% delimit; \unskip then drops it so it doesn't inflate the measured width.
%
% \measurepad is a small kern placed on *both* sides of the content, so glyphs
% don't butt against the barlines (matches the reference's "| text |" breathing
% room).  It's a macro, not a length, so its em is the song-body font at use
% time; retune with \renewcommand.
%
% Line breaks between \measures lines are explicit \\ in the .song, on purpose.
% \measures deliberately does NOT emit its own trailing break: it can't tell
% whether it's the last line of a section, and a trailing \\ before the box
% template's end gives an "Underfull \hbox" warning (breaks the clean-log goal).
% The \\-free alternative is leadsheets' obey-lines (newline => break, no \\),
% which tests clean -- but it's a song-level switch (affects lyric bodies too)
% and changes the spacing knob from \openup\mysonglinesep to obey-lines-parskip,
% so it's a whole-document authoring decision, not a \measures concern.  Leaving
% explicit \\ for now (see CLAUDE.md "Future work" for the obey-lines findings).
\newlength\minmeasure
\setlength\minmeasure{2.0cm}
\newcommand\measurepad{0.35em}
\ExplSyntaxOn
\box_new:N  \l__myls_measure_box
\box_new:N  \l__myls_tmp_box
\dim_new:N  \l__myls_normalbar_dim
\dim_new:N  \l__myls_open_delta_dim
\dim_new:N  \l__myls_close_delta_dim
\dim_new:N  \l__myls_target_dim
\int_new:N  \l__myls_total_int
\int_new:N  \l__myls_index_int
\bool_new:N \l__myls_first_measure_bool
\cs_new_protected:Npn \__myls_openbar:n  #1
  { \str_case:nnF {#1} { {repeat} {\leftrepeat} } {\normalbar} }
\cs_new_protected:Npn \__myls_closebar:n #1
  { \str_case:nnF {#1} { {repeat} {\rightrepeat} {final} {\stopbar} } {\normalbar} }
% #1 = the minimum-width target for this measure; #2 = the measure content.
\cs_new_protected:Npn \__myls_measurebox:nn #1#2
  {
    \hbox_set:Nn \l__myls_measure_box { \kern\measurepad #2 ~ \unskip \kern\measurepad }
    \dim_compare:nNnTF { \box_wd:N \l__myls_measure_box } < {#1}
      { \hbox_to_wd:nn {#1} { \box_use:N \l__myls_measure_box \hfil } }
      { \box_use:N \l__myls_measure_box }
  }
% End-bar width compensation: the opening symbol (|: from \leftrepeat) is the
% first thing on the line, so a wide one shifts every following barline right;
% the closing symbol (:| , |||) overhangs to the right of where a plain | sits.
% Either way a repeat/final line's barlines stop lining up with the plain lines
% above/below it.  We measure each end symbol's *extra* width over a plain bar
% -- open_delta = w(openbar)-w(normalbar), close_delta likewise -- and shrink the
% FIRST measure by open_delta and the LAST by close_delta.  That pulls the first
% barline left into place and slides the closing symbol left so its right edge
% lands exactly where a plain line's final bar does; the middle measures are
% untouched and realign on their own.  A single-measure line is both first and
% last, so it takes both deltas.  For a plain line both deltas are 0, so nothing
% changes.  (Visible only where measures actually hit the minimum -- i.e. charts;
% wide lyric measures don't align anyway, per the "min-width is not a column
% grid" note in CLAUDE.md.)
\NewDocumentCommand \measures { O{} m }
  {
    \hbox_set:Nn \l__myls_tmp_box { \normalbar }
    \dim_set:Nn  \l__myls_normalbar_dim { \box_wd:N \l__myls_tmp_box }
    \hbox_set:Nn \l__myls_tmp_box { \__myls_openbar:n {#1} }
    \dim_set:Nn  \l__myls_open_delta_dim
      { \box_wd:N \l__myls_tmp_box - \l__myls_normalbar_dim }
    \hbox_set:Nn \l__myls_tmp_box { \__myls_closebar:n {#1} }
    \dim_set:Nn  \l__myls_close_delta_dim
      { \box_wd:N \l__myls_tmp_box - \l__myls_normalbar_dim }
    \int_set:Nn  \l__myls_total_int { \tl_count:n {#2} }
    \int_zero:N  \l__myls_index_int
    \bool_set_true:N \l__myls_first_measure_bool
    \tl_map_inline:nn {#2}
      {
        \int_incr:N \l__myls_index_int
        \dim_set:Nn \l__myls_target_dim { \minmeasure }
        \bool_if:NTF \l__myls_first_measure_bool
          {
            \__myls_openbar:n {#1}
            \dim_sub:Nn \l__myls_target_dim { \l__myls_open_delta_dim }
            \bool_set_false:N \l__myls_first_measure_bool
          }
          { \normalbar }
        \int_compare:nNnT { \l__myls_index_int } = { \l__myls_total_int }
          { \dim_sub:Nn \l__myls_target_dim { \l__myls_close_delta_dim } }
        \__myls_measurebox:nn { \l__myls_target_dim } {##1}
      }
    \__myls_closebar:n {#1}
  }
\ExplSyntaxOff

% ---------------------------------------------------------------------------
% Capo variants
% ---------------------------------------------------------------------------
% A capo'd song is written in CONCERT pitch with `capo=N' in its \begin{song}
% properties.  leadsheets' own `transpose-capo' then renders every chord N
% semitones lower -- the shapes actually fretted with the capo on -- and the
% title template (below) adds a "capo N" note.  So the DEFAULT build is the
% capo-shapes sheet and needs no special handling; even a bare vimtex compile is
% correct.  The displayed key stays concert pitch because the title template
% prints \songproperty{key} raw, never through the chord transposer.
%
% The concert-pitch sibling (e.g. for a bass player) is produced by
% compile-songs, which injects \def\ConcertVariant{true} before \input.  That
% turns transpose-capo OFF (chords stay as written = concert) and, via
% \ifMyLSconcert, suppresses the capo note.  A song with no `capo' property is
% unaffected either way: transpose-capo with capo=0 transposes by a full octave,
% i.e. identity (verified -- no enharmonic drift).  NB this means every song must
% set `key=' (concert pitch); leadsheets warns per chord otherwise.
\providecommand\ConcertVariant{false}% `true' only on the script's concert build
\def\MyLSconcertflag{true}% plain \def (not \long) so \ifx matches the injected \def
\newif\ifMyLSconcert
\ifx\ConcertVariant\MyLSconcertflag \MyLSconcerttrue \else \MyLSconcertfalse \fi
\ifMyLSconcert
  \setleadsheets{ transpose-capo = false }
\else
  \setleadsheets{ transpose-capo = true  }
\fi

% ---------------------------------------------------------------------------
% Output variant: chords  (--chords)  -- parallel chart sections
% ---------------------------------------------------------------------------
% The chords variant prints a chord CHART in place of the lyric body, section by
% section, so the two sheets stay structurally identical.  It is selected by
% compile-songs injecting `\def\Variant{chords}' before \input; the
% \providecommand below makes the ordinary build's \Variant resolve to "default".
% (Same injection pattern as the capo/transpose axes.)
%
% Every lyric section type has a parallel CHART TWIN named <type>chords
% (versechords, choruschords, ...).  Each twin is a real leadsheets verse type
% (\newversetype), so it inherits the documented template + auto-numbered-label
% machinery instead of reinventing it:
%   * its DEFAULT template is its counterpart's coloured box (versechords ->
%     versebox), so the chart shares the lyric section's colour and the .song
%     writes a bare \begin{versechords} -- no [template=] needed;
%   * it carries its own counter and the same label scheme (V1:/C1:/In:), so the
%     labels line up section-for-section across the two sheets when the lyric and
%     chart bodies are authored in parallel.
% The twin's body is the \measures chart (vs. the lyric body in verse/chorus/...).
%
% Exactly one family renders per build; the other family's environments are
% redefined to swallow their body (xparse `+b') -- the unused body produces no
% output and no box, hence no under/overfull warnings and no leadsheets
% internals.  In the chords build the lyric types are swallowed; in every other
% build the chart twins are swallowed.  Both lists below must stay complete: a
% lyric type missing from the first leaks its lyrics into the chords sheet; a
% twin missing from the second leaks its chart into the lyric sheet.
% \RenewDocumentEnvironment errors on a non-existent name, keeping the lists
% honest against the definitions here.

% --- define the chart twins (always; suppressed on the wrong side below) ------
% The [template=...] option sets each twin's *default* template, so the .song
% needs no per-instance [template=].
\newversetype{versechords}      [template=versebox]
\newversetype{choruschords}     [template=chorusbox]
\newversetype{introchords}      [template=introbox]
\newversetype{outrochords}      [template=outrobox]
\newversetype{interludechords}  [template=interludebox]
\newversetype{bridgechords}     [template=bridgebox]
\newversetype{solochords}       [template=solobox]
\newversetype{prechoruschords}  [template=prechorusbox]
\newversetype{postchoruschords} [template=postchorusbox]
\newversetype{liftchords}       [template=liftbox]
\newversetype{custompartchords} [template=custompartbox]

% --- mirror each twin's label onto its lyric counterpart ----------------------
% Same scheme as the lyric label block above: numbered twins reuse the one-letter
% prefix, named twins reuse the short name, so the labels match section for
% section.  choruschords deliberately does NOT inherit chorus's italic -- it
% takes the global (upright, bold) verses-format, like every other chart.
\setleadsheets{
  versechords/named=false,  versechords/numbered=true,  versechords/after-label=: ,
  choruschords/named=false, choruschords/numbered=true, choruschords/after-label=: ,
  introchords/name=In ,
  outrochords/name=Out ,
  interludechords/name=I/L ,
  bridgechords/name=Br ,
  solochords/name=S ,
  prechoruschords/name=Pr ,
  postchoruschords/name=Po ,
  liftchords/name=L ,
  custompartchords/name=Part ,
}
\renewcommand\theversechords{V\arabic{versechords}}
\renewcommand\thechoruschords{C\arabic{choruschords}}

% --- select which family renders ----------------------------------------------
% \Variant is one of: default, chords, lyrics (phone planned).  Only `chords'
% renders the chart twins; `lyrics' and `default' both print the lyric bodies and
% swallow the twins -- they differ only in print-chords (set near the file end):
% `lyrics' additionally suppresses the ^{C} chords, leaving words alone.
\providecommand\Variant{default}
\def\MyLSchordsflag{chords}
\newif\ifMyLSchords
\ifx\Variant\MyLSchordsflag \MyLSchordstrue \else \MyLSchordsfalse \fi
\def\MyLSlyricsflag{lyrics}
\newif\ifMyLSlyrics
\ifx\Variant\MyLSlyricsflag \MyLSlyricstrue \else \MyLSlyricsfalse \fi
\ExplSyntaxOn
\ifMyLSchords
  % chords build: lyric types swallow their body; chart twins render.
  \clist_map_inline:nn
    {
      verse, verse*, chorus, chorus*, intro, intro*, outro, interlude,
      bridge, info, solo, solo*, prechorus, prechorus*,
      lift, postchorus, custompart
    }
    { \RenewDocumentEnvironment {#1} { O{} +b } {} {} }
\else
  % every other build: chart twins swallow their body; lyric types render.
  \clist_map_inline:nn
    {
      versechords, choruschords, introchords, outrochords, interludechords,
      bridgechords, solochords, prechoruschords, postchoruschords,
      liftchords, custompartchords
    }
    { \RenewDocumentEnvironment {#1} { O{} +b } {} {} }
\fi
\ExplSyntaxOff

% ---------------------------------------------------------------------------
% Per-section \minmeasure override
% ---------------------------------------------------------------------------
% A `minmeasure' key on every section type, so one section can widen (or narrow)
% its measure floor without disturbing the rest:
%
%   \begin{versechords}[minmeasure=3cm] ... \end{versechords}
%
% This matters most in chart (chords) sections, where wider bars line the
% barlines up more evenly -- but it is available on the lyric types too (e.g. an
% intro/outro built with \measures).  The override is automatically local: a
% leadsheets section is a TeX group, and the key runs through the environment's
% \keys_set inside that group, so \setlength reverts to the global \minmeasure
% (set in the "Measures" block above) at \end.  Wider content still keeps its
% natural width -- this only moves the *minimum*, exactly like \minmeasure.
%
% The key is added to the leadsheets/<type> path of every managed section type
% (lyric types + their chart twins) via \keys_define -- additive and documented,
% no private internals.  The helper is defined with \cs_new so the key-value
% parameter (##1 -> #1 when the macro runs) stays unambiguous through the loop.
\ExplSyntaxOn
\cs_new_protected:Npn \__myls_add_minmeasure_key:n #1
  {
    \keys_define:nn {leadsheets/#1}
      { minmeasure .code:n = { \setlength \minmeasure {##1} } }
  }
\clist_map_inline:nn
  {
    verse, chorus, intro, outro, interlude, bridge, solo,
    prechorus, postchorus, lift, custompart,
    versechords, choruschords, introchords, outrochords, interludechords,
    bridgechords, solochords, prechoruschords, postchoruschords,
    liftchords, custompartchords
  }
  { \__myls_add_minmeasure_key:n {#1} }
\ExplSyntaxOff

% ---------------------------------------------------------------------------
% Song title / header
% ---------------------------------------------------------------------------
% One-line header "Title (Band) Tempo Key" (key in brick-red), replacing the
% class default of "Title" + a second "as played by: ..., key: ..." line.
% \definesongtitletemplate is the documented mechanism.
\definesongtitletemplate{mytitle}{%
  \section*{%
    \ifsongproperty{difficulty}{\songproperty{difficulty}\space}{}%
    \large\sffamily\songproperty{title}\space\normalsize\mdseries
    \ifsongproperty{band}{(\songproperty{band})\space}{}%
    \ifsongproperty{tempo}{\songproperty{tempo}\space}{}%
    \ifsongproperty{key}{\bfseries\textcolor{BrickRed}{\songproperty{key}}}{}%
    \ifMyLSconcert\else
      \ifsongproperty{capo}{\nobreakspace\notebox{capo \songproperty{capo}}}{}%
    \fi
    \ifsongproperty{tuning}{\space\small\songproperty{tuning}\normalsize}{}%
  }%
}
\setleadsheets{ title-template = mytitle }

% No running header and no page numbers.  The class (via scrlayer-scrpage) puts
% the song title in the page header (pages 2+) and a "page X of Y" line in the
% footer; \clearpairofpagestyles wipes every head/foot slot of the scrheadings
% pagestyle (and its plain variant) in one documented command.
\clearpairofpagestyles

% Chords print in every build except the lyrics variant, which strips the ^{C}
% chords to leave the words alone (the only thing distinguishing it from the
% default build -- see the variant-selection block above).
\ifMyLSlyrics
  \setleadsheets{ print-chords = false }
\else
  \setleadsheets{ print-chords = true  }
\fi
