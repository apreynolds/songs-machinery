\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{MyLeadsheets}

\def\normalbarwidth{.15em}

\RequirePackage[T1]{fontenc}
\RequirePackage[defaultsans]{lato}
\RequirePackage[scale=0.96]{newtxtt}

\newcommand\MyMargin{1.5cm}
\RequirePackage[margin=\MyMargin,letterpaper]{geometry}

% ---------------------------------------------------------------------------
% Coloured song-section boxes  (approach B: one template per part type)
% ---------------------------------------------------------------------------
% Every leadsheets part type (verse, chorus, ...) is given its own
% tcolorbox-based "template", with its colour written directly into the
% template.  Writing \begin{verse} ... \end{verse} in the .song file then
% wraps the section in its coloured box -- no outer wrapper environment.
\RequirePackage[dvipsnames]{xcolor}
\RequirePackage{tcolorbox}

% --- shared box body -------------------------------------------------------
% The colour (#1) is the only thing that varies between part types; the rest
% reproduces the package's built-in "itemize" template (songs library) so the
% section label \verselabel keeps its normal placement.  Defined under
% \ExplSyntaxOn only to reach the package's internal obey-lines handling.
\ExplSyntaxOn
\NewDocumentCommand \myleadsheetsboxbegin { m }
  {
    \tcolorbox [ left=0pt, right=0pt, boxrule=0mm, arc=0mm, colback=#1 ]
    \itemize
    \int_zero:N \@itemdepth
    \bool_if:NT \l__leadsheets_obey_lines_bool
      {
        \dim_zero:N \parskip
        \keys_set:nn { leadsheets } { obey-lines-parskip = \parsep }
      }
    \item [ { \verselabel } ]
  }
\NewDocumentCommand \myleadsheetsboxend { }
  { \enditemize \endtcolorbox }
\ExplSyntaxOff

% --- one template per part type, colour written in directly -----------------
\defineversetypetemplate {versebox}     { \myleadsheetsboxbegin{Gray!6} }        { \myleadsheetsboxend }
\defineversetypetemplate {chorusbox}    { \myleadsheetsboxbegin{Green!9} }       { \myleadsheetsboxend }
\defineversetypetemplate {solobox}      { \myleadsheetsboxbegin{RoyalPurple!14} }{ \myleadsheetsboxend }
\defineversetypetemplate {introbox}     { \myleadsheetsboxbegin{Dandelion!10} }  { \myleadsheetsboxend }
\defineversetypetemplate {outrobox}     { \myleadsheetsboxbegin{Dandelion!10} }  { \myleadsheetsboxend }
\defineversetypetemplate {interludebox} { \myleadsheetsboxbegin{Dandelion!15} }  { \myleadsheetsboxend }
\defineversetypetemplate {bridgebox}    { \myleadsheetsboxbegin{RoyalBlue!14} }  { \myleadsheetsboxend }

% --- point each part type at its own template ------------------------------
\ExplSyntaxOn
\keys_set:nn { leadsheets/verse }     { template = versebox }
\keys_set:nn { leadsheets/chorus }    { template = chorusbox }
\keys_set:nn { leadsheets/solo }      { template = solobox }
\keys_set:nn { leadsheets/intro }     { template = introbox }
\keys_set:nn { leadsheets/outro }     { template = outrobox }
\keys_set:nn { leadsheets/interlude } { template = interludebox }
\keys_set:nn { leadsheets/bridge }    { template = bridgebox }
\ExplSyntaxOff
