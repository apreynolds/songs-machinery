\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{MyLeadsheets}

\def\normalbarwidth{.09em}

% Barline LENGTH (height).  leadsheets draws every bar as a \rule whose length is
% hardwired to the current font size: \genericbar sets \leadsheets@barheight =
% \leadsheets@size and the rule runs from -0.2x (depth) to +0.8x (above baseline).
% There is a public knob for bar *width* (\normalbarwidth, above) but none for
% length, so scale it at the one chokepoint every bar funnels through.
% \MyLSbarheightscale multiplies the rule's length (and the -0.2 depth with it, so
% the bar grows symmetrically and stays centred the same); 1 = stock height.
% This REACHES INTO a leadsheets @-internal (\genericbar / \leadsheets@size /
% \leadsheets@barheight) because there is no documented bar-length API -- the
% minimal targeted override.  thick / repeat / stop bars all compose \genericbar,
% so they scale together; the repeat ':' colon is a separate text glyph and does
% not scale (negligible).  \leadsheets@size is read at bar-use time, so this keeps
% tracking the font size.
\newcommand\MyLSbarheightscale{1.25}
\renewrobustcmd*\genericbar[1]{%
  \setlength\leadsheets@barheight\leadsheets@size
  \setlength\leadsheets@barheight{\MyLSbarheightscale\leadsheets@barheight}%
  \rule[-.2\leadsheets@barheight]{#1}{\leadsheets@barheight}%
}

\RequirePackage[T1]{fontenc}
\RequirePackage[defaultsans]{lato}
\RequirePackage[scale=0.96]{newtxtt}

% Make the document body sans by default so .song files need no \sffamily after
% \begin{document}.  lato's [defaultsans] sets Lato as the *sans* family but
% leaves \familydefault at the roman family; repointing it at \sfdefault is the
% standard LaTeX route (newtxtt still supplies \ttfamily, used by chords/measures).
\renewcommand*\familydefault{\sfdefault}

% ---------------------------------------------------------------------------
% Output view selection  (\View)
% ---------------------------------------------------------------------------
% A single command-line lever -- `\def\View{...}', injected by build-pdfs before
% \input -- picks one view.  The CONTENT axis is one of: full (default), chords,
% lyrics, debug, phone.  An orthogonal grayscale MODIFIER composes with the
% content axis: tokens `chords-gray', `lyrics-gray' and `gray'/`full-gray' (the
% last two = full content, colour off).
%
% The modifier is stripped FIRST (below): a recognised gray token sets
% \ifMyLSgray and reduces \View to its bare content view, so the content-axis
% detection that follows -- and every downstream branch (geometry, family
% selection, remarks filtering, print-chords) -- sees only the plain base name
% and is completely unchanged.  Only the xcolor load (adds the `monochrome'
% package option) and the section-box background react to \ifMyLSgray.
%
% Detected ONCE here, near the top, so the geometry block just below (the `phone'
% view needs a taller page), the xcolor load, the songbook helpers (phone skips
% odd-page padding), the back-to-contents link (larger in phone) and the
% family-selection block much further down can all branch on the same \newif flags.
\providecommand\View{full}
% --- strip the orthogonal grayscale modifier (must run before content detection)
\newif\ifMyLSgray
\def\MyLSgraybare{gray}          \ifx\View\MyLSgraybare   \MyLSgraytrue \def\View{full}   \fi
\def\MyLSgrayfull{full-gray}     \ifx\View\MyLSgrayfull   \MyLSgraytrue \def\View{full}   \fi
\def\MyLSgraychords{chords-gray} \ifx\View\MyLSgraychords \MyLSgraytrue \def\View{chords} \fi
\def\MyLSgraylyrics{lyrics-gray} \ifx\View\MyLSgraylyrics \MyLSgraytrue \def\View{lyrics} \fi
% --- content axis (\View now free of any grayscale modifier)
\newif\ifMyLSchords \def\MyLSchordsflag{chords} \ifx\View\MyLSchordsflag \MyLSchordstrue \fi
\newif\ifMyLSlyrics \def\MyLSlyricsflag{lyrics} \ifx\View\MyLSlyricsflag \MyLSlyricstrue \fi
\newif\ifMyLSdebug  \def\MyLSdebugflag{debug}   \ifx\View\MyLSdebugflag  \MyLSdebugtrue  \fi
\newif\ifMyLSphone  \def\MyLSphoneflag{phone}   \ifx\View\MyLSphoneflag  \MyLSphonetrue  \fi

% ---------------------------------------------------------------------------
% Page geometry  (geometry kept on purpose -- see CLAUDE.md design goals)
% ---------------------------------------------------------------------------
% Default views share one tight letterpaper layout (8.5x11in, 0.3cm margins).
% The `phone' view is deliberately the *same* layout -- same width, same margins,
% same font -- but on a taller page (8.5x22in), so a song that fits the usual
% "two letter pages" soft target lands on a single tall "phone page" read as one
% continuous scroll.  Songs longer than that simply flow onto a second phone
% page.  CONTENT is identical to the `full' view (lyric bodies, chords over
% words -- see the family-selection block below, where `phone' takes the same
% path as `full').  Only the height is a knob:
\newcommand\MyMargin{0.3cm}
\newcommand\MyLSphoneheight{22in}    % phone-page height (~ two letter pages tall)
\ifMyLSphone
  \RequirePackage[paperwidth=8.5in,paperheight=\MyLSphoneheight,%
                  margin=\MyMargin]{geometry}
\else
  \RequirePackage[margin=\MyMargin,letterpaper]{geometry}
\fi

% ---------------------------------------------------------------------------
% Extra song-part types
% ---------------------------------------------------------------------------
% Part types beyond the package/class defaults, used across the song corpus.
% \newversetype is the documented command for defining a verse-like environment;
% their names, colours and templates are configured below alongside the built-in
% types.  (prechorus is already provided by the leadsheet class, so it only needs
% naming/colouring, not defining here.)
\newversetype{lift}
\newversetype{postchorus}
\newversetype{custompart}   % generic catch-all section (was "mypart" in the reference)

% ---------------------------------------------------------------------------
% \resize -- single-knob vertical tightener
% ---------------------------------------------------------------------------
% A song's parts are atomic (a verse/chorus/... never splits across a page), so
% a part that *just* overflows bumps wholesale to the next page and leaves the
% blank tail behind.  \resize lets one document buy back a little vertical room
% -- WITHOUT touching font size, page geometry, or any horizontal measure -- by
% scaling the three vertical-space contributors by a single factor:
%   1. interline gap inside a section  (\openup\mysonglinesep, default 1ex)
%   2. section-box internal padding    (tcolorbox top/bottom 2mm, boxsep 1mm)
%   3. gap *between* consecutive boxes  (beforeafter skip, 0.5\baselineskip)
% Item 2/3's stock numbers are tcolorbox's reset defaults (the boxes leave those
% keys unset today); \resize sets them explicitly, so factor 1 reproduces the
% current output byte-for-byte and is an exact no-op.  Put \resize[0.95] before
% OR after \begin{document}: the factor is read live at each box and each
% section-format expansion, so placement is free.  <1 tightens, >1 loosens.
% Font size is deliberately NOT scaled (every song is destined for a shared
% songbook, where uniform type matters) and chords stay \normalsize.  The factor
% multiplies ON TOP of the base knobs (\mysonglinesep, the 2mm/1mm box padding),
% so the two compose -- \resize is the per-document "smush everything a touch"
% lever, the named lengths stay the per-quantity ones.  Default 0.95 is a gentle
% nudge; pass a smaller number (0.9, 0.85) to smush harder.
\newcommand\MyLSrf{1}                       % resize factor; 1 = stock spacing
\newcommand\resize[1][0.95]{\renewcommand\MyLSrf{#1}}

% ---------------------------------------------------------------------------
% Coloured song-section boxes  (approach B, plain-LaTeX style)
% ---------------------------------------------------------------------------
% Each leadsheets part type (verse, chorus, ...) gets its own tcolorbox-based
% "template".  Templates are the package's documented extension point
% (\defineversetypetemplate, manual section "verse-type templates").  Writing
% \begin{verse} ... \end{verse} in the .song file then wraps the section in
% its coloured box -- no outer wrapper environment is needed.
%
% Everything here uses the package's *documented* template commands
% (\verselabel, \ifobeylines, \setleadsheets), patterned on the manual's own
% "itemize" template, so no LaTeX3 (expl3) syntax is needed at all.
% The grayscale modifier (print-friendly) adds xcolor's `monochrome' option, which
% switches colour output off entirely: every \color / \textcolor / coloured glyph
% falls back to black ink.  The coloured section boxes are forced to a white
% background separately (see \myleadsheetsboxbegin), so monochrome only needs to
% handle the inline colour (chords, noteboxes, \bg, difficulty/genre glyphs).
\ifMyLSgray
  \RequirePackage[dvipsnames,monochrome]{xcolor}
\else
  \RequirePackage[dvipsnames]{xcolor}
\fi
\RequirePackage{tcolorbox}

% --- shared box body -------------------------------------------------------
% The colour (#1) is the only thing that varies between part types.  The rest
% reproduces the package's built-in "itemize" template so the section label
% \verselabel keeps its normal placement; we only add the tcolorbox around it.
% \makeatletter is needed solely for \@itemdepth, a standard LaTeX list
% internal -- exactly as the manual's own itemize example uses it.
% \MyLSboxcolback expands to the part-type colour normally, or to `white' under
% the grayscale modifier -- so the section boxes lose their tint (no border is
% added; boxrule stays 0mm) and print on plain white, while the rest of the page
% goes black-on-white via xcolor's monochrome option (see the xcolor load above).
\newcommand\MyLSboxcolback[1]{\ifMyLSgray white\else #1\fi}
\makeatletter
\newcommand\myleadsheetsboxbegin[1]{%
  % top/bottom/boxsep and beforeafter skip are tcolorbox's own reset defaults,
  % restated here only so \MyLSrf (\resize) can scale them; at factor 1 the box
  % is unchanged.  See the \resize block above.
  \tcolorbox[left=0pt,right=0pt,boxrule=0mm,arc=0mm,colback=\MyLSboxcolback{#1},%
    top=\MyLSrf\dimexpr2mm\relax, bottom=\MyLSrf\dimexpr2mm\relax,%
    boxsep=\MyLSrf\dimexpr1mm\relax,%
    beforeafter skip balanced={\MyLSrf\dimexpr0.5\baselineskip\relax plus 2pt}]%
  \itemize
  \@itemdepth=0
  \ifobeylines
    {\setlength{\parskip}{0pt}\setleadsheets{obey-lines-parskip=\parsep}}%
    {}%
  \item[{\verselabel}]%
}
\makeatother
\newcommand\myleadsheetsboxend{\enditemize\endtcolorbox}

% --- one template per part type, colour written in directly ----------------
% Each part type's box is its DEFAULT template (set just below), so a bare
% \begin{verse} in the .song is already boxed -- no [template=versebox] needed.
% The named templates remain as override hooks: pass [template=chorusbox] to
% borrow another type's box, or [template=itemize] for a plain (un-boxed)
% section.  (The chart twins set the same defaults via \newversetype, further
% down, so the lyric and chart families look identical.)
\defineversetypetemplate{versebox}     {\myleadsheetsboxbegin{Gray!6}}        {\myleadsheetsboxend}
\defineversetypetemplate{chorusbox}    {\myleadsheetsboxbegin{Green!9}}       {\myleadsheetsboxend}
\defineversetypetemplate{solobox}      {\myleadsheetsboxbegin{RoyalPurple!14}}{\myleadsheetsboxend}
\defineversetypetemplate{introbox}     {\myleadsheetsboxbegin{Dandelion!10}}  {\myleadsheetsboxend}
\defineversetypetemplate{outrobox}     {\myleadsheetsboxbegin{Dandelion!10}}  {\myleadsheetsboxend}
\defineversetypetemplate{interludebox} {\myleadsheetsboxbegin{Dandelion!15}}  {\myleadsheetsboxend}
\defineversetypetemplate{bridgebox}    {\myleadsheetsboxbegin{RoyalBlue!14}}  {\myleadsheetsboxend}
\defineversetypetemplate{liftbox}      {\myleadsheetsboxbegin{Green!5}}       {\myleadsheetsboxend}
\defineversetypetemplate{prechorusbox} {\myleadsheetsboxbegin{Green!5}}       {\myleadsheetsboxend}
\defineversetypetemplate{postchorusbox}{\myleadsheetsboxbegin{Green!5}}       {\myleadsheetsboxend}
\defineversetypetemplate{custompartbox}{\myleadsheetsboxbegin{white}}         {\myleadsheetsboxend} % untinted

% --- make each box the part type's DEFAULT template ------------------------
% `template' is the documented per-type key (leadsheets/<type> path, same public
% API as verse/named etc. below).  Setting it here means the coloured box is
% applied automatically, so the .song writes a bare \begin{verse} and the
% [template=...] option is needed only to override (borrow another box, or
% [template=itemize] for a plain section).  prechorus is a class built-in;
% lift/postchorus/custompart were \newversetype'd above; all accept this key.
\setleadsheets{
  verse/template       = versebox ,
  chorus/template      = chorusbox ,
  intro/template       = introbox ,
  outro/template       = outrobox ,
  interlude/template   = interludebox ,
  bridge/template      = bridgebox ,
  solo/template        = solobox ,
  prechorus/template   = prechorusbox ,
  postchorus/template  = postchorusbox ,
  lift/template        = liftbox ,
  custompart/template  = custompartbox ,
}

% ---------------------------------------------------------------------------
% Section labels: short names, numbered where appropriate
% ---------------------------------------------------------------------------
% Recurring sections auto-number with a compact one-letter prefix (V1:, C1:,
% ...) from a bare \begin{verse} / \begin{chorus}; one-off sections show a short
% name (In:, S:, Out:).  Every label ends in ":" and is set in the normal
% (non-bold) weight.  All documented: the options go through \setleadsheets, and
% the prefixes come from standard LaTeX counter formatting
% (\renewcommand\the<counter>, which also drops the default trailing ".").
% Override any single section in the .song file with, e.g.,
%   \begin{verse}[named=true,numbered=false,name=Pre-chorus]
% (handy for repeats or out-of-sequence labels, which auto-numbering can't do).

% Recurring, auto-numbered: number plus the ":" separator (e.g. V1:).
\setleadsheets{
  verse/named=false,   verse/numbered=true,   verse/after-label=: ,
  chorus/named=false,  chorus/numbered=true,  chorus/after-label=: ,
}
\renewcommand\theverse{V\arabic{verse}}
\renewcommand\thechorus{C\arabic{chorus}}

% Default extra line spacing inside song sections, so a bare "\\" gives a
% comfortable gap -- no need for \\[1ex] on every line.  A bare \\ now spans
% baselineskip + \mysonglinesep; \\[<len>] still adds <len> more on a specific
% break.  Tune \mysonglinesep to change the default everywhere.
\newlength\mysonglinesep
\setlength\mysonglinesep{1ex}

% Section body text in bold (matches the reference); labels are kept un-bold via
% verses-label-format=\mdseries, overriding the class default of \bfseries
% (leadsheet.cls:145).  \openup widens the interline spacing (see \mysonglinesep
% above) without pushing chords off their lyrics.  chorus needs its own line:
% the class sets a per-type chorus/format=\itshape (leadsheet.cls:147) that
% shadows the global verses-format, so re-assert \bfseries there for bold *and*
% keep its (desired) italic.  (The class italicises info/format the same way.)
\setleadsheets{
  verses-format       = {\bfseries\openup\MyLSrf\mysonglinesep} ,
  verses-label-format = \mdseries ,
  chorus/format       = {\bfseries\itshape\openup\MyLSrf\mysonglinesep} ,
}

% One-off, named (not numbered; all use the default ":" separator).  Short
% abbreviations taken from the reference; adjust to taste.  custompart is meant
% to be overridden per section with [name=...], "Part" is just its fallback.
\setleadsheets{
  intro/name=In ,
  solo/name=S ,
  outro/name=Out ,
  bridge/name=Br ,
  interlude/name=I/L ,
  prechorus/name=Pr ,
  postchorus/name=Po ,
  lift/name=L ,
  custompart/name=Part ,
}

% ---------------------------------------------------------------------------
% Chords: brick-red, bold, sans
% ---------------------------------------------------------------------------
% chords/format is the documented chord-formatting hook (manual: the "chords/"
% options).  Specifying the whole font -- not just the colour -- keeps chords
% bold sans regardless of the surrounding section format (e.g. they stay sans
% in the italic chorus, though they inherit its slant, as in the reference).
% align-chords=l left-aligns each chord to the start of the word it sits over
% (the package default is centred); this matches the reference.
\setleadsheets{
  chords/format = {\sffamily\normalsize\bfseries\color{BrickRed}} ,
  align-chords  = l ,
}

% ---------------------------------------------------------------------------
% Inline markers
% ---------------------------------------------------------------------------
% Small TikZ/boxed glyphs dropped inline in a lyric or \measures line.  They
% depend only on packages already loaded above (TikZ via tcolorbox, colours via
% xcolor); \leadinto additionally pulls in TikZ's arrows.meta library (loaded at
% its definition), but still no extra \RequirePackage.
%
%   \notebox{<text>} -- boxed performance note, e.g. \notebox{pause}.  LOAD-
%       BEARING: the capo header label (\notebox{capo N}, title template below)
%       uses it; also used directly in several .song files.  Kept.
%   \note{<text>}    -- lighter inline tag: a bold typewriter `[text]' in blue,
%       no frame, for a quick bracketed annotation.  The un-boxed sibling of
%       \notebox; used in .song bodies.
%   \repeatbar       -- TikZ-drawn repeat glyph (two dots + a slash), used as
%       $\repeatbar$ in legacy raw-pipe .song files.  Ported from the reference
%       .sty so those files compile.  (Whether repeat marks might instead live in
%       the \measures builder is noted in CLAUDE.md, but is not planned.)  Kept.
%   \beatdot / \beat -- brick-red beat dot marking a sustained-chord beat.
%       \beatdot is the BARE dot for OVER-A-WORD use (^{\beatdot}); \beat is the
%       self-spacing standalone marker for charts (| A \beat \beat B |), padded by
%       the tunable \beatspace.  See their definition block below for the why.
%   \mydot           -- DEPRECATED alias for the bare \beatdot, kept only so
%       legacy archive .song files keep compiling.  Emits a ONE-time-per-document
%       deprecation warning (see \MyLSmydotwarning).  A clean (converted) song uses
%       \beatdot / \beat and never triggers it; the converter rewrites \mydot away.
%   \leadinto{WORD}  -- sets WORD as a "pickup" lead-in to the next section:
%       a short, thick right-arrow on each side, WORD itself italic, slightly
%       smaller, and faux-slanted a touch beyond italic.  Replaces the kernel
%       $\rightarrow$ (thin, curved) and folds the old
%       \leadinto\emph{WORD}\leadinto idiom into one argument-taking command so
%       the styling lives in one place.  Plain text (no math mode).
% \noteboxcolor is the single retune point for both the frame and the text
% colour (matches \minmeasure/\measurepad as tunable knobs).  \fboxsep is set
% locally so the padding is deterministic, not inherited from the ambient
% \fboxsep; \raisebox's box group scopes the assignment, so it reverts on exit.
% The 0.1em lift nudges the box onto the surrounding text baseline.
\newcommand\noteboxcolor{RoyalBlue}
\newcommand\notebox[1]{%
  \raisebox{0.1em}{%
    \setlength\fboxsep{2pt}%
    \fcolorbox{\noteboxcolor}{White}{%
      \bfseries\ttfamily\upshape\textcolor{\noteboxcolor}{#1}%
    }%
  }%
}
\newcommand\note[1]{%
  {\bfseries\ttfamily \textcolor{RoyalBlue}{[#1]}}
}

% \meter{<num>}{<den>}: leadsheets' stacked time-signature symbol, recoloured so
% a bare \meter{12}{8} in a .song carries the colour automatically -- no more
% hand-wrapping each one in \textcolor{...}.  The original is preserved under
% \MyLSmeterorig and re-wrapped in \textcolor; \mymetercolor is the single retune
% point (matches \noteboxcolor), defaulting to BrickRed to match the chords.
% \renewrobustcmd keeps \meter robust (etoolbox, already loaded via leadsheets).
% Safe to override: nothing inside leadsheets uses \meter itself.
\newcommand\mymetercolor{BrickRed}
\let\MyLSmeterorig\meter
\renewrobustcmd*\meter[2]{\textcolor{\mymetercolor}{\MyLSmeterorig{#1}{#2}}}

% \ssp / \bsp: manual horizontal nudge-spacers for fine-tuning spacing inside
% \measures (or anywhere inline).  The *amounts* live in length registers so a
% .song body can retune them with \setlength\ssplength{4pt} (repeatable, and local
% to a TeX group such as a section), without redefining the spacer macro.  Uses
% \hspace* so an explicit nudge is never silently discarded at a line break.
\newlength\ssplength  \setlength\ssplength{8pt}    % small space
\newlength\msplength  \setlength\msplength{16pt}   % medium space
\newlength\bsplength  \setlength\bsplength{24pt}   % big space
\newlength\xsplength  \setlength\xsplength{32pt}   % xl space
\newcommand\ssp{\hspace*{\ssplength}}
\newcommand\msp{\hspace*{\msplength}}
\newcommand\bsp{\hspace*{\bsplength}}
\newcommand\xsp{\hspace*{\xsplength}}

\newcommand\repeatbar{%
  \begin{tikzpicture}[baseline=0ex]
    \draw (0,0) ;
    \filldraw[BrickRed] (0.2,0.3) circle (1.5pt) ;
    \draw[line width=2pt,BrickRed] (0.2,-0.05) -- (0.6,0.38) ;
    \filldraw[BrickRed] (0.6,0.04) circle (1.5pt) ;
  \end{tikzpicture}%
}
% --- Beat markers: \beatdot (bare) and \beat (self-spacing) -----------------
% A small brick-red dot marking a beat where the previous chord sustains.  Two
% forms, because the two contexts need opposite spacing behaviour:
%
%   \beatdot  -- the BARE dot, no horizontal space of its own.  Use it OVER A
%       WORD as ^{\beatdot} ("this word lands on a later beat, chord still
%       ringing", e.g. ^{A}FUNNY ^{\beatdot}TO BE): the ^ chord mechanism already
%       positions it, so any built-in \hspace would shove the dot off the word
%       and widen the lyric.  Also the glyph \beat is built from.
%
%   \beat     -- the STANDALONE beat marker for chord charts: a \beatdot wrapped
%       in \beatspace, so "| A \beat \beat B |" spreads the beats across the bar
%       with no hand-added spacers.  \beatspace is the single tunable knob
%       (\setlength\beatspace{...} anywhere; local to a TeX group, e.g. a
%       section).  \hspace* (not \hspace) so the space is never dropped at a line
%       break.  Do NOT use \beat inside ^{}/_{} -- use \beatdot there.
%
% baseline=0ex sits the dot just above the text baseline (as the old \mydot did).
\newcommand\beatdot{%
  \begin{tikzpicture}[baseline=0ex]
    \filldraw[BrickRed] (0,0.12) circle (0.9pt) ;
  \end{tikzpicture}%
}
\newlength\beatspace
\setlength\beatspace{1.5em}
\newcommand\beat{\hspace*{.5\beatspace}\beatdot\hspace*{.5\beatspace}}
% \mydot -- DEPRECATED alias for the bare \beatdot, kept so legacy archive .song
% files (1000+ uses) still compile.  Fires \PackageWarning ONCE (then \global\let-s
% the warning to \relax so the log gets one line, not one per use), and \protect
% keeps the control sequences literal in the message.  Clean (converted) songs use
% \beatdot / \beat and never trigger it; the converter rewrites \mydot away.
\newcommand\MyLSmydotwarning{%
  \PackageWarning{MyLeadsheets}{%
    \protect\mydot\space is deprecated; use \protect\beatdot\space (over a word)
    or \protect\beat\space (standalone)}%
  \global\let\MyLSmydotwarning\relax
}
\newcommand\mydot{\MyLSmydotwarning\beatdot}

% \leadinto{WORD} is built from two pieces, both reusing already-loaded TikZ.
%
% \MyLSleadarrow -- one short, thick shaft with a filled triangular head (Latex
%   tip, from arrows.meta; \usetikzlibrary is idempotent and may sit anywhere in
%   the preamble, so it lives next to its only user).  baseline=-0.5ex drops the
%   shaft onto the text's math axis so it centres on the line.  Drawn once, used
%   on both sides, both pointing right ("leads into / continues").
%
% The word is set in a one-node picture so it can be faux-slanted past italic:
%   xslant shears the glyphs by x' = x + slant*y.  It MUST be applied as a
%   coordinate transformation (xslant + transform shape), NOT as a canvas
%   transformation (transform canvas={xslant=...}): canvas transforms are
%   invisible to TikZ's bounding-box computation, which collapses the picture to
%   ZERO width so the two arrows close over the word.  As a coordinate transform
%   the sheared box is measured normally (a hair wider than upright), so the word
%   occupies its space.  The shear fixes the y=0 line and the node's base sits at
%   y=0, so the text baseline is untouched and the word still sits on the line --
%   only the ascenders/descenders lean.  The node inherits the ambient weight
%   (bold in song sections), so \itshape gives bold-italic and \small shrinks it.
%
% Knobs: \MyLSleadarrowlen (shaft length), the line width / tip size below, and
% \MyLSleadslant (extra slant; set to 0 for plain italic).
\usetikzlibrary{arrows.meta}
\newlength\MyLSleadarrowlen
\setlength\MyLSleadarrowlen{0.6em}
\newcommand\MyLSleadslant{0.18}
\newcommand\MyLSleadarrow{%
  \begin{tikzpicture}[baseline=-0.5ex]
    \draw[line width=1.3pt,-{Latex[length=3.5pt,width=4.5pt]}]
      (0,0) -- (\MyLSleadarrowlen,0) ;
  \end{tikzpicture}%
}
\newcommand\leadinto[1]{%
  \MyLSleadarrow%
  \begin{tikzpicture}[baseline=(w.base)]
    \node[inner sep=0pt,anchor=base,transform shape,xslant=\MyLSleadslant]
      (w) at (0,0) {\small\itshape #1} ;
  \end{tikzpicture}%
  \MyLSleadarrow
}

% ---------------------------------------------------------------------------
% Difficulty ratings
% ---------------------------------------------------------------------------
% A song carries an optional difficulty glyph via the custom song property
% `difficulty`, written by the author as one of the three symbol macros below,
% e.g. \begin{song}[]{title=..., difficulty={\moderate}}.  The glyph prints as a
% leading marker in the title header (see the title template).
%
% These are drawn in TikZ (already loaded via tcolorbox) rather than set as
% amssymb math glyphs (\bullet/\blacktriangle/\blacklozenge): song sheets do no
% mathematical typesetting, so pulling in amssymb just for three shapes is
% avoidable weight.  (The only other "math" symbols a song uses -- \rightarrow,
% \Uparrow -- are LaTeX-kernel symbols that need no amssymb either, so dropping
% it costs nothing.)  This also matches the existing inline markers (\repeatbar,
% \mydot), which are likewise hand-drawn TikZ.
%
% \MyLSdifficultysize is the single size knob (glyph height); each shape is drawn
% in a unit box scaled by it (x/y = that length), so coordinates read as
% fractions of the glyph size.  baseline=-0.5ex sits the picture's y=0 near the
% text's math axis, vertically centring the glyph on the title.  Colours: easy =
% ForestGreen, moderate = RoyalBlue (dvipsnames); difficult stays black for
% contrast, as in the reference.
\newlength\MyLSdifficultysize
\setlength\MyLSdifficultysize{0.78em}
\newcommand\MyLSdifficultyglyph[2]{% #1 = colour, #2 = fill path in the unit box
  \begin{tikzpicture}[baseline=-0.5ex,x=\MyLSdifficultysize,y=\MyLSdifficultysize]
    \fill[#1] #2 ;
  \end{tikzpicture}%
}
\newcommand\easy     {\MyLSdifficultyglyph{ForestGreen}{(0,0) circle (0.5)}}
\newcommand\moderate {\MyLSdifficultyglyph{RoyalBlue}{(0,0.5) -- (-0.45,-0.35) -- (0.45,-0.35) -- cycle}}
\newcommand\difficult{\MyLSdifficultyglyph{black}{(0,0.5) -- (0.4,0) -- (0,-0.5) -- (-0.4,0) -- cycle}}

% Transpose indicator -- \transup / \transdown arrow glyphs and the `istransposed'
% property that renders them in the header.  RATIONALE: it is useful to see at a
% glance that a song has been moved off its written key (e.g. dropped a few
% semitones to sing it comfortably) without reaching for the original -- at a
% campfire one usually just plays the original key.  `istransposed' is a PURELY
% COSMETIC marker: it changes nothing musical, unlike leadsheets' built-in
% `transpose=' (which moves the sounding pitch) or `capo=' (fingering shapes).
% It just prints a small arrow, plus an optional amount, after the key.
%
% Authoring:  istransposed={up 3}  -> up-arrow + "3"
%             istransposed={down 2}-> down-arrow + "2"
%             istransposed={up}    -> bare up-arrow (no amount)
% The first word selects the arrow; the rest (if any) is printed after it.
% \transup / \transdown also remain as standalone glyph macros and still work as a
% legacy property value (istransposed={\transup 2}) via the \str_case fallback in
% \MyLStransposed below.
%
% Drawn in TikZ (already loaded via tcolorbox), matching the difficulty glyphs
% above.  \MyLStransposecolor tints both the arrow and the amount.  The up glyph
% is a stem + arrowhead; \transdown is the same picture flipped vertically
% (yscale=-1).  The baseline is the bounding box's SOUTH edge -- i.e. the glyph's
% lowest drawn point -- so it sits ON the text baseline: that point is the tail
% for the up arrow and the (downward) tip for the down arrow, exactly the two ends
% asked to touch the baseline.
%
% SIZE: the glyph fills 1.0 unit vertically (y from -0.5 to 0.5), so its height
% equals the x/y scale length.  That length is the height of a digit in the
% CURRENT font, measured per-draw with \settoheight -- so the arrow is exactly as
% tall as the amount beside it and tracks the heading/TOC font automatically.
% \MyLStransposescale is an optional fine-tune multiplier on that height (1 = exact
% digit height) -- the only size knob; there is no fixed length to set.
\newcommand\MyLStransposescale{1}
\newcommand\MyLStransposecolor{BrickRed}
\newlength\MyLStransarrowht   % scratch: measured digit height * scale, set per-draw
\newcommand\MyLStransposearrowpic[1]{% #1 = +1 (up) or -1 (down): flip with yscale
  \settoheight\MyLStransarrowht{8}%
  \setlength\MyLStransarrowht{\MyLStransposescale\MyLStransarrowht}%
  \begin{tikzpicture}[baseline={(current bounding box.south)},%
                      x=\MyLStransarrowht,y=\MyLStransarrowht,yscale=#1]
    \fill[\MyLStransposecolor] (-0.09,-0.5) rectangle (0.09,0.12) ;
    \fill[\MyLStransposecolor] (-0.30,0.06) -- (0.30,0.06) -- (0,0.5) -- cycle ;
  \end{tikzpicture}%
}
% Robust (\NewDocumentCommand) so a stray \transup baked into the .toc survives
% \edef -- see \MyLStransposed below for why that matters in a songbook.
\NewDocumentCommand\transup  {}{\MyLStransposearrowpic{1}}
\NewDocumentCommand\transdown{}{\MyLStransposearrowpic{-1}}
% \MyLStransposed{<value>} -- render an `istransposed' property value.  Robust,
% so it survives into a songbook TOC the same way \notebox{capo ...} does: the
% title template writes \MyLStransposed{\songproperty{istransposed}} to the .toc,
% where \edef bakes the \songproperty value in (the song context is still live)
% but leaves \MyLStransposed for \tableofcontents to execute -- so the rich glyph
% reaches the TOC entry, not raw text.
\ExplSyntaxOn
\tl_new:N \l__myls_transposed_tl
% \MyLStransposed is robust, so it grabs \songproperty{istransposed} UNEXPANDED;
% expand it first (\tl_set:Ne, leaving the robust \transup/\transdown tokens
% intact) so the splitter sees the actual value's space, then append a trailing
% space as the splitter's delimiter and hand off.
\NewDocumentCommand\MyLStransposed { m }
  {
    \tl_set:Ne \l__myls_transposed_tl { #1 ~ }
    \exp_after:wN \__myls_transposed:w \l__myls_transposed_tl \q_stop
  }
% Split the value on its first space: #1 = direction word, #2 = amount (possibly
% blank).  `up'/`down' map to the arrow; anything else (a legacy \transup /
% \transdown token) is emitted unchanged.  The amount, if present, is trimmed of
% the delimiter's trailing space.  The whole marker is wrapped in BrickRed
% parentheses -- one \textcolor over the lot (the arrow sets its own fill, so the
% colour is consistent; the parens and amount inherit it).
\cs_new_protected:Npn \__myls_transposed:w #1 ~ #2 \q_stop
  {
    \textcolor{\MyLStransposecolor}
      {
        (
        \str_case:nnF {#1}
          { {up} {\MyLStransposearrowpic{1}} {down} {\MyLStransposearrowpic{-1}} }
          {#1}%
        \tl_if_blank:nF {#2} { \, \tl_trim_spaces:n {#2} }
        )
      }
  }
\ExplSyntaxOff

% `difficulty', `tuning' and `arrangement' are not leadsheets built-ins
% (unlike title/band/tempo/key/capo), so each must be registered with
% \definesongproperty before \songproperty{...} / \ifsongproperty{...} work.
\definesongproperty{difficulty}
\definesongproperty{tuning}
\definesongproperty{arrangement}
% `istransposed' -- the cosmetic transpose marker (see \transup / \MyLStransposed
% above); rendered in the title template, after the key.  Distinct from
% leadsheets' built-in `transpose='.  Registered like the others so
% \ifsongproperty / \songproperty work.
\definesongproperty{istransposed}

% \fixedchord{<chord>} -- renders a chord name with leadsheets' symbol formatting
% (# -> sharp symbol, b -> flat symbol, etc.) WITHOUT applying any transposition.
%
% Use case: the `key' song property, when you want to display the concert-pitch
% key regardless of transpose= or capo= settings.  Example:
%   key={\fixedchord{F\sharp m}}   key={\fixedchord{B\flat}}
%
% ACCIDENTALS: write \sharp / \flat, NOT a literal `#'.  A raw `#' renders fine
% in a standalone sheet, but the heading is reused verbatim as the songbook TOC
% entry and written to the .aux/.toc; under hyperref the `#' is stringified and
% DOUBLED to `##', which re-tokenises on read-back as a parameter character and
% errors ("You can't use macro parameter character #' in horizontal mode").
% \sharp/\flat are control sequences (no `#' byte to double) and are exactly the
% glyphs \writechord converts `#'/`b' into, so the printed result is identical.
%
% Implementation note: transposition in \writechord is gated on two private
% expl3 booleans in the leadsheets package:
%   \l__leadsheets_transpose_bool       (set by transpose=N in \begin{song})
%   \l__leadsheets_transpose_capo_bool  (set by capo=N in \begin{song})
% We temporarily set both to false inside a group (expl3 \l__ variables are
% local, so they are restored automatically when the group ends).
%
% WARNING -- private API: these variable names are internal to leadsheets
% (double-underscore prefix).  If leadsheets is ever updated and renames or
% restructures them, this macro will silently stop suppressing transposition
% (or may cause an error).  The leadsheets package appears unmaintained as of
% 2025, so the risk is low, but check this macro if leadsheets is ever updated.
% The relevant source is leadsheets.library.chords.code.tex,
% \__leadsheets_chord_write:n.
\ExplSyntaxOn
\NewDocumentCommand \fixedchord { m }
{
  \group_begin:
  \bool_set_false:N \l__leadsheets_transpose_bool
  \bool_set_false:N \l__leadsheets_transpose_capo_bool
  \writechord {#1}
  \group_end:
}
\ExplSyntaxOff
% \MyLSformattuning{<value>} -- render a tuning's accidentals as proper glyphs,
% with NO chord parsing and NO transposition.  Applied automatically by the title
% template to \songproperty{tuning}, so a .song writes plain text -- tuning={Eb},
% tuning={DADGAD}, tuning={drop D} -- with no wrapper macro to remember.
%
% Why NOT \writechord (the way \fixedchord handles the key)?  \writechord routes
% through \chordname, which does two things we must avoid on a tuning:
%   (a) it transposes by the song's transpose=/capo= amount -- but a tuning is a
%       fixed fact about the instrument and must never move; and
%   (b) it parses chord *quality* -- superscripting digits, turning a lone `o'
%       into a diminished mark, `+' into aug, `(...)' into tensions.  Run over a
%       descriptive tuning that mangles it: "drop D" -> "dr" + superscript-o
%       + "p D", "open G" likewise.
% So we bypass \chordname entirely and do ONLY the accidental substitution.
%
% This is safe precisely because note letters are uppercase (D A G B ...) while a
% flat is a lowercase `b': replacing lowercase `b' -> \flat never touches a
% B-note, and "drop"/"open"/"tuning" contain no lowercase b either.  \sharp and
% \flat are leadsheets' own text-safe accidental glyphs (musicsymbols library) --
% the same ones \writechord prints -- so a tuning matches the chords visually.
%
% \tl_set:Ne first expands \songproperty{tuning} to its stored value.  That value
% was rescanned with `#' catcode-other when the property was set
% (properties.code.tex, \leadsheets_set_property:nnn), so the sharp search must
% match a catcode-other `#'; \c_hash_str is exactly that, and the Nen variant
% expands it in the search position.  (No private leadsheets internals here -- a
% notch cleaner than \fixedchord, which has to flip two \l__leadsheets_ booleans.)
\ExplSyntaxOn
\tl_new:N \l__myls_tuning_tl
\cs_generate_variant:Nn \tl_replace_all:Nnn { Nen }
\NewDocumentCommand \MyLSformattuning { m }
  {
    \tl_set:Ne \l__myls_tuning_tl {#1}
    \tl_replace_all:Nen \l__myls_tuning_tl { \c_hash_str } { \sharp }
    \tl_replace_all:Nnn \l__myls_tuning_tl { b } { \flat }
    \tl_use:N \l__myls_tuning_tl
  }
\ExplSyntaxOff

% ---------------------------------------------------------------------------
% Measures: minimum bar spacing
% ---------------------------------------------------------------------------
% leadsheets' bar "|" is just an inline rule; the span between two bars has no
% width of its own, so sparse measures (a lone chord) collapse to nothing.
% \measures typesets one music line as a list of measures, each set in a
% left-aligned box of at least \minmeasure -- so barlines never sit closer than
% that, while lyric-heavy measures keep their (larger) natural width.
%
%   \measures{ {m1}{m2}{m3} }         ->  normal bars   | m1 | m2 | m3 |
%   \measures[repeat]{ {m1}{m2} }     ->  repeat bars   |: m1 | m2 :|
%   \measures[repeatstart]{ {m1}{m2} }->  open repeat   |: m1 | m2 |
%   \measures[repeatend]{ {m1}{m2} }  ->  close repeat  | m1 | m2 :|
%   \measures[final]{ {m1}{m2} }      ->  final bar     | m1 | m2 |||
%
% repeatstart/repeatend split the repeat across several \measures lines: open the
% passage with [repeatstart], close it with [repeatend], plain lines in between.
%
% The .song stays clean -- one braced group per measure -- and the iteration
% lives here.  expl3 is deliberate: \tl_map_inline:nn maps cleanly over brace
% groups (each measure is one list item), which plain LaTeX does only awkwardly.
% Bar styles go through \str_case so adding \doublebar etc. is a one-line edit.
%
% The literal space + \unskip inside the box is load-bearing: the chord splitter
% (\__leadsheets_set_chord:nwn) scans forward to a space to find the lyric a
% chord sits over, so a measure ending "^{Em}LOVE" needs a trailing space to
% delimit; \unskip then drops it so it doesn't inflate the measured width.
%
% \measurepad is a small kern placed on *both* sides of the content, so glyphs
% don't butt against the barlines (matches the reference's "| text |" breathing
% room).  It's a macro, not a length, so its em is the song-body font at use
% time; retune with \renewcommand.
%
% Line breaks between \measures lines are explicit \\ in the .song, on purpose.
% \measures deliberately does NOT emit its own trailing break: it can't tell
% whether it's the last line of a section, and a trailing \\ before the box
% template's end gives an "Underfull \hbox" warning (breaks the clean-log goal).
% The \\-free alternative is leadsheets' obey-lines (newline => break, no \\),
% which tests clean -- but it's a song-level switch (affects lyric bodies too)
% and changes the spacing knob from \openup\mysonglinesep to obey-lines-parskip,
% so it's a whole-document authoring decision, not a \measures concern.  Leaving
% explicit \\ for now.
\newlength\minmeasure
\setlength\minmeasure{2.0cm}
\newcommand\measurepad{0.35em}
\ExplSyntaxOn
\box_new:N  \l__myls_measure_box
\box_new:N  \l__myls_tmp_box
\dim_new:N  \l__myls_normalbar_dim
\dim_new:N  \l__myls_open_delta_dim
\dim_new:N  \l__myls_close_delta_dim
\dim_new:N  \l__myls_target_dim
\int_new:N  \l__myls_total_int
\int_new:N  \l__myls_index_int
\bool_new:N \l__myls_first_measure_bool
\bool_new:N \l__myls_bg_bool              % backing-vocals de-emphasis (\bg ... \bgoff)
\cs_new_protected:Npn \__myls_openbar:n  #1
  { \str_case:nnF {#1} { {repeat} {\leftrepeat} {repeatstart} {\leftrepeat} } {\normalbar} }
\cs_new_protected:Npn \__myls_closebar:n #1
  { \str_case:nnF {#1}
      { {repeat} {\rightrepeat} {repeatend} {\rightrepeat} {final} {\stopbar} }
      {\normalbar} }
% #1 = the minimum-width target for this measure; #2 = the measure content.
\cs_new_protected:Npn \__myls_measurebox:nn #1#2
  {
    \hbox_set:Nn \l__myls_measure_box
      { \kern\measurepad \bool_if:NT \l__myls_bg_bool {\MyLSbgfont} #2 ~ \unskip \kern\measurepad }
    \dim_compare:nNnTF { \box_wd:N \l__myls_measure_box } < {#1}
      { \hbox_to_wd:nn {#1} { \box_use:N \l__myls_measure_box \hfil } }
      { \box_use:N \l__myls_measure_box }
  }
% End-bar width compensation: the opening symbol (|: from \leftrepeat) is the
% first thing on the line, so a wide one shifts every following barline right;
% the closing symbol (:| , |||) overhangs to the right of where a plain | sits.
% Either way a repeat/final line's barlines stop lining up with the plain lines
% above/below it.  We measure each end symbol's *extra* width over a plain bar
% -- open_delta = w(openbar)-w(normalbar), close_delta likewise -- and shrink the
% FIRST measure by open_delta and the LAST by close_delta.  That pulls the first
% barline left into place and slides the closing symbol left so its right edge
% lands exactly where a plain line's final bar does; the middle measures are
% untouched and realign on their own.  A single-measure line is both first and
% last, so it takes both deltas.  For a plain line both deltas are 0, so nothing
% changes.  (Visible only where measures actually hit the minimum -- i.e. charts;
% wide lyric measures don't align anyway, per the "min-width is not a column
% grid" note in CLAUDE.md.)
\NewDocumentCommand \measures { O{} m }
  {
    \hbox_set:Nn \l__myls_tmp_box { \normalbar }
    \dim_set:Nn  \l__myls_normalbar_dim { \box_wd:N \l__myls_tmp_box }
    \hbox_set:Nn \l__myls_tmp_box { \__myls_openbar:n {#1} }
    \dim_set:Nn  \l__myls_open_delta_dim
      { \box_wd:N \l__myls_tmp_box - \l__myls_normalbar_dim }
    \hbox_set:Nn \l__myls_tmp_box { \__myls_closebar:n {#1} }
    \dim_set:Nn  \l__myls_close_delta_dim
      { \box_wd:N \l__myls_tmp_box - \l__myls_normalbar_dim }
    \int_set:Nn  \l__myls_total_int { \tl_count:n {#2} }
    \int_zero:N  \l__myls_index_int
    \bool_set_true:N \l__myls_first_measure_bool
    \tl_map_inline:nn {#2}
      {
        \int_incr:N \l__myls_index_int
        \dim_set:Nn \l__myls_target_dim { \minmeasure }
        \bool_if:NTF \l__myls_first_measure_bool
          {
            \__myls_openbar:n {#1}
            \dim_sub:Nn \l__myls_target_dim { \l__myls_open_delta_dim }
            \bool_set_false:N \l__myls_first_measure_bool
          }
          { \normalbar }
        \int_compare:nNnT { \l__myls_index_int } = { \l__myls_total_int }
          { \dim_sub:Nn \l__myls_target_dim { \l__myls_close_delta_dim } }
        \__myls_measurebox:nn { \l__myls_target_dim } {##1}
      }
    \__myls_closebar:n {#1}
    \bool_gset_false:N \l__myls_bg_bool   % \bg is per-line: auto-off at the line end
  }
\ExplSyntaxOff

% ---------------------------------------------------------------------------
% Backing-vocals de-emphasis:  \bg ... \bgoff
% ---------------------------------------------------------------------------
% Renders lyric text a touch smaller and grey -- for backing vocals worth keeping
% but worth subordinating, e.g. "(follow me, don't follow me)".  A SWITCH, not a
% wrapping \bg{...}, on purpose: backing vocals usually run across several measure
% cells, and wrapping each cell leaves unbalanced "(" / ")" inside braces (awkward
% to type, and it upsets editor brace/paren matching).
%
% Each measure cell is set in its own box (its own group), so a plain font switch
% would not carry from one cell to the next.  \bg therefore sets a GLOBAL flag that
% \__myls_measurebox honours (greying every cell while set) and also applies the
% font for the rest of its own cell; \bgoff clears the flag AND restores normal
% text (\MyLSbgreset) for the rest of its own cell.  The flag is auto-cleared at
% the end of every \measures line (above), so it cannot bleed past the line even if
% \bgoff is forgotten -- a deliberate per-line scope; re-open with \bg on the next
% line if a backing-vocal run continues.  Chords are unaffected: the chord format
% resets size and colour itself, so only the lyric text greys.  Retune the look via
% \MyLSbgfont / \MyLSbgcolor.
%
% POSITION RELATIVE TO A CHORD IS MEANINGFUL (not a gotcha).  A `^{chord}' binds
% whatever IMMEDIATELY follows it as the word set under the chord (leadsheets scans
% up to the next space, in its own grouped tabular).  So three distinct forms:
%   \bg ^{A}word    chord OVER the de-emphasised word  -- \bg goes BEFORE the chord
%   ^{A} \bg word   chord FLOATS FREE, lyric starts after the hit  -- the space
%                   after the chord gives it an empty slot, detaching it on purpose
%   ^{A}\bg word    AMBIGUOUS, AVOID -- \bg is captured as the chord's word and set
%                   inside that group, so the grey reverts after just that one word
% \bgoff follows the same rule: end a run on a plain word (Word\bgoff) or before a
% chord; never ^{A}\bgoff.  (So the reliable habit is positional -- put \bg/\bgoff
% before a chord, not after -- NOT "a space on each side", which forces the
% detaching space when the switch follows a chord.)
%
%   \measures{%
%     {\bg ^{E5}(follow me, don't}      % E5 over "(follow"
%     {^{E5}follow me) \bgoff}          % E5 over "follow"; run ends on the word
%     {^{G}GOT my SPINE I've}
%     {^{D}GOT my ORANGE CRUSH}
%   }
\newcommand\MyLSbgcolor{gray}
\newcommand\MyLSbgfont{\small\color{\MyLSbgcolor}}
% \MyLSbgreset undoes \MyLSbgfont: \bgoff applies it so text AFTER a mid-cell
% \bgoff returns to normal (the measure box greys the whole cell, so clearing the
% flag alone wouldn't restore the rest of the current cell).
\newcommand\MyLSbgreset{\normalsize\normalcolor}
\ExplSyntaxOn
\newcommand\bg    { \bool_gset_true:N  \l__myls_bg_bool \MyLSbgfont }
\newcommand\bgoff { \bool_gset_false:N \l__myls_bg_bool \MyLSbgreset }
\ExplSyntaxOff

% ---------------------------------------------------------------------------
% Capo
% ---------------------------------------------------------------------------
% A capo'd song is written in CONCERT pitch with `capo=N' in its \begin{song}
% properties.  leadsheets' own `transpose-capo' then renders every chord N
% semitones lower -- the shapes actually fretted with the capo on -- and the
% title template (below) adds a "capo N" note via \ifsongproperty{capo}.  So a
% capo wrapper needs no special handling; even a bare vimtex compile is correct.
% The displayed key stays concert pitch because the title template prints
% \songproperty{key} raw, never through the chord transposer.
%
% Different pitches/keys of one song are now separate wrapper .song files that
% each \input a shared body (the "arrangement-by-wrapper" strategy -- see CLAUDE.md
% "Output views and arrangements").  The concert sibling is simply a wrapper that OMITS
% `capo=N' (so nothing transposes and the note is absent), and a real key change
% is a wrapper carrying `transpose=N'.  No \ConcertArrangement / \SongTranspose
% injection and no per-build toggling of transpose-capo is needed any more, so
% transpose-capo is just set true once, globally.
%
% A song with no `capo' property is unaffected: transpose-capo with capo absent
% (or capo=0) is a full-octave transpose = identity (verified -- no enharmonic
% drift).  NB every song must still set `key=' (concert pitch); leadsheets warns
% per chord otherwise.
\setleadsheets{ transpose-capo = true }

% ---------------------------------------------------------------------------
% Output view: chords  (--chords)  -- parallel chart sections
% ---------------------------------------------------------------------------
% The chords view prints a chord CHART in place of the lyric body, section by
% section, so the two sheets stay structurally identical.  It is selected by
% build-pdfs injecting `\def\View{chords}' before \input; the
% \providecommand below makes the ordinary build's \View resolve to "full".
% (The chords/lyrics axis is now the only magic-comment-driven view; capo and
% transpose are separate wrapper .song files, not injected build flags.)
%
% Every lyric section type has a parallel CHART TWIN named <type>chords
% (versechords, choruschords, ...).  Each twin is a real leadsheets verse type
% (\newversetype), so it inherits the documented template + auto-numbered-label
% machinery instead of reinventing it:
%   * its DEFAULT template is its counterpart's coloured box (versechords ->
%     versebox), so the chart shares the lyric section's colour and the .song
%     writes a bare \begin{versechords} -- no [template=] needed;
%   * it carries its own counter and the same label scheme (V1:/C1:/In:), so the
%     labels line up section-for-section across the two sheets when the lyric and
%     chart bodies are authored in parallel.
% The twin's body is the \measures chart (vs. the lyric body in verse/chorus/...).
%
% Exactly one family renders per build; the other family's environments are
% redefined to swallow their body (xparse `+b') -- the unused body produces no
% output and no box, hence no under/overfull warnings and no leadsheets
% internals.  In the chords build the lyric types are swallowed; in every other
% build the chart twins are swallowed.  Both lists below must stay complete: a
% lyric type missing from the first leaks its lyrics into the chords sheet; a
% twin missing from the second leaks its chart into the lyric sheet.
% \RenewDocumentEnvironment errors on a non-existent name, keeping the lists
% honest against the definitions here.

% --- define the chart twins (always; suppressed on the wrong side below) ------
% The [template=...] option sets each twin's *default* template, so the .song
% needs no per-instance [template=].
\newversetype{versechords}      [template=versebox]
\newversetype{choruschords}     [template=chorusbox]
\newversetype{introchords}      [template=introbox]
\newversetype{outrochords}      [template=outrobox]
\newversetype{interludechords}  [template=interludebox]
\newversetype{bridgechords}     [template=bridgebox]
\newversetype{solochords}       [template=solobox]
\newversetype{prechoruschords}  [template=prechorusbox]
\newversetype{postchoruschords} [template=postchorusbox]
\newversetype{liftchords}       [template=liftbox]
\newversetype{custompartchords} [template=custompartbox]

% --- mirror each twin's label onto its lyric counterpart ----------------------
% Same scheme as the lyric label block above: numbered twins reuse the one-letter
% prefix, named twins reuse the short name, so the labels match section for
% section.  choruschords deliberately does NOT inherit chorus's italic -- it
% takes the global (upright, bold) verses-format, like every other chart.
\setleadsheets{
  versechords/named=false,  versechords/numbered=true,  versechords/after-label=: ,
  choruschords/named=false, choruschords/numbered=true, choruschords/after-label=: ,
  introchords/name=In ,
  outrochords/name=Out ,
  interludechords/name=I/L ,
  bridgechords/name=Br ,
  solochords/name=S ,
  prechoruschords/name=Pr ,
  postchoruschords/name=Po ,
  liftchords/name=L ,
  custompartchords/name=Part ,
}
\renewcommand\theversechords{V\arabic{versechords}}
\renewcommand\thechoruschords{C\arabic{choruschords}}

% --- select which family renders ----------------------------------------------
% \View is one of: full, chords, lyrics, debug, phone -- detected near the top of
% this file (the geometry block needs the `phone' flag early).  `chords' renders
% the chart twins and swallows the lyric bodies; `lyrics', `full' and `phone'
% print the lyric bodies and swallow the twins.  `lyrics' alone differs in
% print-chords (set near the file end), suppressing the ^{C} chords to leave the
% words; `phone' differs from `full' only in page height (above), not content,
% so it takes the same family path here.  `debug' swallows NOTHING, printing both
% families in one sheet (chords on, like default) for proofing line lengths /
% spacing -- see the three-way selection below.
\ExplSyntaxOn
\ifMyLSdebug
  % debug build: swallow NOTHING -- both the lyric types and their chart twins
  % render, so one sheet shows everything (proofing line lengths, spacing, and
  % bar alignment of lyric body + chord chart without flipping between PDFs).
\else
  \ifMyLSchords
    % chords build: lyric types swallow their body; chart twins render.
    \clist_map_inline:nn
      {
        verse, verse*, chorus, chorus*, intro, intro*, outro, interlude,
        bridge, info, solo, solo*, prechorus, prechorus*,
        lift, postchorus, custompart
      }
      { \RenewDocumentEnvironment {#1} { O{} +b } {} {} }
  \else
    % every other build: chart twins swallow their body; lyric types render.
    \clist_map_inline:nn
      {
        versechords, choruschords, introchords, outrochords, interludechords,
        bridgechords, solochords, prechoruschords, postchoruschords,
        liftchords, custompartchords
      }
      { \RenewDocumentEnvironment {#1} { O{} +b } {} {} }
  \fi
\fi
\ExplSyntaxOff

% ---------------------------------------------------------------------------
% Per-section \minmeasure override
% ---------------------------------------------------------------------------
% A `minmeasure' key on every section type, so one section can widen (or narrow)
% its measure floor without disturbing the rest:
%
%   \begin{versechords}[minmeasure=3cm] ... \end{versechords}
%
% This matters most in chart (chords) sections, where wider bars line the
% barlines up more evenly -- but it is available on the lyric types too (e.g. an
% intro/outro built with \measures).  The override is automatically local: a
% leadsheets section is a TeX group, and the key runs through the environment's
% \keys_set inside that group, so \setlength reverts to the global \minmeasure
% (set in the "Measures" block above) at \end.  Wider content still keeps its
% natural width -- this only moves the *minimum*, exactly like \minmeasure.
%
% The key is added to the leadsheets/<type> path of every managed section type
% (lyric types + their chart twins) via \keys_define -- additive and documented,
% no private internals.  The helper is defined with \cs_new so the key-value
% parameter (##1 -> #1 when the macro runs) stays unambiguous through the loop.
\ExplSyntaxOn
\cs_new_protected:Npn \__myls_add_minmeasure_key:n #1
  {
    \keys_define:nn {leadsheets/#1}
      { minmeasure .code:n = { \setlength \minmeasure {##1} } }
  }
\clist_map_inline:nn
  {
    verse, chorus, intro, outro, interlude, bridge, solo,
    prechorus, postchorus, lift, custompart,
    versechords, choruschords, introchords, outrochords, interludechords,
    bridgechords, solochords, prechoruschords, postchoruschords,
    liftchords, custompartchords
  }
  { \__myls_add_minmeasure_key:n {#1} }
\ExplSyntaxOff

% ---------------------------------------------------------------------------
% Arrangement slot (leading title marker)
% ---------------------------------------------------------------------------
% A song may carry an optional `arrangement' property -- a short monospace tag
% naming which arrangement this sheet is (arrangement={pno.}, {gtr.}, {capo}, ...).
% It prints as a bracketed, coloured monospace marker [pno.] at the very start of
% the title header, to the LEFT of the title (font, colour and vertical lift are
% the \MyLSarrangement{font,color,raise} knobs below).
%
% The slot has a MINIMUM width of 6 monospace characters (= "[xxxx]": a 4-char
% word in brackets), left-aligned.  So an arrangement tag of 4 characters or fewer
% fills the box exactly, and across a songbook TOC every tagged title indents to the
% same x and lines up; a longer word grows the box and pushes its own title
% further in (acceptable).  An EMPTY value (arrangement={}) still reserves the box --
% a blank 6-char indent -- so an untagged sibling of a tagged song can be
% aligned with it by writing arrangement={}.  An ABSENT arrangement prints nothing
% (title flush left).  \ifsongproperty distinguishes the two in the template: it is
% built on \prop_if_in: (leadsheets.library.properties.code.tex), i.e. it tests
% whether the property KEY is set, not whether the value is non-empty -- so
% arrangement={} is true (box) while an unset arrangement is false (no box).
%
% Robust, and measures at point of use: the title doubles as the songbook TOC
% entry, so the heading -- and this macro -- is written to the .toc and re-typeset
% there.  \NewDocumentCommand makes \MyLSarrangementslot robust (it survives the write
% intact, like \MyLSformattuning), and measuring the 6-char minimum inside the
% macro lets the box adapt to the TOC's font context as well as the page's, so the
% indent stays self-consistent in each.  Pure standard LaTeX3 boxes/dims -- no
% leadsheets internals.
\newcommand\MyLSarrangementfont{\normalsize\ttfamily}
\newcommand\MyLSarrangementcolor{RoyalBlue}% colour of the whole tag (brackets + word)
\newcommand\MyLSarrangementraise{0.15ex}% lift, to sit the tag higher against the \large title
\ExplSyntaxOn
\tl_new:N \l__myls_arrangement_tl
\box_new:N \l__myls_arrangement_box
\box_new:N \l__myls_arrangement_ref_box
\NewDocumentCommand \MyLSarrangementslot { m }
  {
    % the marker: bracket a non-empty value (brackets included in the colour);
    % leave an empty one blank so the box stays a plain indent
    \tl_set:Ne \l__myls_arrangement_tl {#1}
    \hbox_set:Nn \l__myls_arrangement_box
      {
        \MyLSarrangementfont
        \tl_if_empty:NF \l__myls_arrangement_tl
          { \textcolor{\MyLSarrangementcolor}{[\tl_use:N \l__myls_arrangement_tl]} }
      }
    % reference width = 6 monospace chars in the same font (all mono glyphs are
    % equal width, so any 6 characters give the right measure)
    \hbox_set:Nn \l__myls_arrangement_ref_box { \MyLSarrangementfont 000000 }
    % emit left-aligned and raised a little to sit higher against the \large
    % title: pad to the 6-char minimum when narrower, else use the natural width
    \dim_compare:nNnTF
      { \box_wd:N \l__myls_arrangement_box } < { \box_wd:N \l__myls_arrangement_ref_box }
      {
        \raisebox{\MyLSarrangementraise}
          { \hbox_to_wd:nn { \box_wd:N \l__myls_arrangement_ref_box }
              { \box_use:N \l__myls_arrangement_box \hfill } }
      }
      { \raisebox{\MyLSarrangementraise}{\box_use:N \l__myls_arrangement_box} }
    \space
  }
\ExplSyntaxOff

% ---------------------------------------------------------------------------
% Song title / header
% ---------------------------------------------------------------------------
% One-line header "[arrangement] Title (Band) Key [capo] ..... [genre][difficulty]"
% (arrangement a mono tag, key in brick-red, genre/difficulty pushed to the right
% margin), replacing the class default of "Title" + a second "as played by: ...,
% key: ..." line.  \definesongtitletemplate is the documented mechanism.
% The header is a real \section (not \section*), so in a songbook it is picked
% up automatically by \tableofcontents -- and the TOC line carries the full,
% richly formatted header (arrangement, key, capo, genre, difficulty), which is the
% whole point of reusing the heading as the TOC text.  (Tuning is the one piece
% deliberately kept OUT of the heading -- see the tuning line below.)  Under
% hyperref the section also seeds a PDF bookmark, but a bookmark is a plain
% string: the spacing/content macros in the header (\quad, \hfill, \fixedchord
% inside key=, \MyLSarrangementslot, ...) are not valid there and would each log a
% "Token not allowed" warning (the font commands -- \large, \sffamily, ... --
% hyperref strips silently).  So the entire
% heading is wrapped in one \texorpdfstring: the FIRST (rich) branch is what gets
% typeset and written to the TOC; the SECOND branch is a clean, hand-written
% string (title, band) that hyperref uses for the bookmark.  Nothing inside the
% rich branch needs individual wrapping -- it never reaches the PDF string.
%
% \texorpdfstring is hyperref's.  Song sheets that don't load hyperref still need
% \section to work, so provide a no-op fallback (first branch wins) at
% begin-document -- after all packages have loaded, so \providecommand sees the
% real macro when hyperref IS present and stays quiet (no "Redefining" log line).
\AtBeginDocument{\providecommand\texorpdfstring[2]{#1}}
% Font for the optional second "Tuning:" line (see below), and the amount it is
% pulled up toward the heading (applied as negative space above the line).
\newcommand\MyLStuningfont{\small}
\newcommand\MyLStuningraise{0.5\baselineskip}
\definesongtitletemplate{mytitle}{%
  \section{\texorpdfstring{%
    \ifsongproperty{arrangement}{\MyLSarrangementslot{\songproperty{arrangement}}}{}%
    \large\sffamily\songproperty{title}\space\mdseries
    \ifsongproperty{band}{(\songproperty{band})}{}\normalsize\quad%
    \ifsongproperty{key}{\space\songproperty{key}}{}%
    \ifsongproperty{istransposed}{\nobreakspace\MyLStransposed{\songproperty{istransposed}}}{}%
    \ifsongproperty{capo}{\nobreakspace\notebox{capo \songproperty{capo}}}{}%
    % genre and difficulty share the right margin, in that order.  Emit the
    % \hfill that pushes them right only when at least one is present -- a lone
    % trailing \hfill would split the stretch with the TOC linefill (see the
    % \DeclareTOCStyleEntry note below).  Nested EXPANDABLE \ifsongproperty only:
    % \ifanysongproperty is \NewDocumentCommand (not expandable), so it would not
    % fold away when the heading is written to the .toc and would instead run at
    % \tableofcontents time -- when the current-song context is gone -- giving the
    % wrong answer in the TOC.
    \ifsongproperty{genre}{%
      \hfill\textcolor{ForestGreen}{\songproperty{genre}}%
      \ifsongproperty{difficulty}{\space\songproperty{difficulty}}{}%
    }{%
      \ifsongproperty{difficulty}{\hfill\songproperty{difficulty}}{}%
    }%
  }{%
    \songproperty{title}%
    \ifsongproperty{band}{ (\songproperty{band})}{}%
  }}%
  % Tuning (rare): a second line BELOW the heading.  Emitted after \section{} --
  % i.e. outside the heading -- so it never reaches the TOC entry, the PDF
  % bookmark, or the running head (all three derive from the \section title).
  % \nopagebreak ties it to the heading above; the paragraph after a KOMA section
  % is unindented by default, so no \noindent is needed.  The negative \vspace
  % (\MyLStuningraise) pulls the line up to sit closer under the title.
  \ifsongproperty{tuning}{%
    \nopagebreak\vspace{-\MyLStuningraise}\nopagebreak
    {\MyLStuningfont Tuning: \MyLSformattuning{\songproperty{tuning}}}\par
  }{}%
}
\setleadsheets{ title-template = mytitle }

% Song headings are \section, so they carry a number by default ("1 Title ...").
% Song sheets never want a numbered header, so drop the number everywhere with
% secnumdepth=0: the heading and its TOC line lose the leading number, but the
% song still appears in a songbook's TOC and bookmarks (that is governed by
% tocdepth, not secnumdepth).
\setcounter{secnumdepth}{0}

% Drop the page number from each TOC line (songbook only -- a single sheet has no
% TOC).  KOMA's section TOC entry uses the documented `section' entry style with
% a `pagenumberformat' command-option.  Its value is treated as a COMMAND applied
% to the page number, so an empty value ({}) still prints the number ({}{<n>}); a
% one-arg "discard" command drops it instead.  KOMA re-tokenises the stored value
% with the catcodes in force when the TOC is typeset (where @ is NOT a letter),
% so the kernel's \@gobble can't be used here -- its @ would print as text.
% Hence this @-free gobbler.  KOMA-native, no \l@section hack.
\newcommand*\MyLSgobblepagenumber[1]{}
% linefill=\hfil too: KOMA inserts a `linefill' (here a plain \hfill -- section
% TOC entries have no dot leaders) between the entry text and the page number.
% That is a SECOND \hfill alongside the one the title template uses to push
% `genre' right, so the two split the space and genre lands mid-line.  We can't
% just drop the linefill: KOMA needs *some* line-end fill, or genre-less entries
% get justified (inter-word spread).  Instead make the linefill a weaker order of
% infinity, \hfil (1fil) vs the template's \hfill (1fill): with a genre present
% its \hfill wins all the stretch so genre is flush right and the \hfil collapses;
% with no genre the lone \hfil still absorbs the slack, keeping the line ragged.
% pagenumberwidth=0pt: with the page number gobbled, KOMA still reserves a box of
% width \@pnumwidth on the right, which insets genre ~22pt from the text margin;
% zeroing it lets genre reach the true right edge (matching the on-page heading).
\DeclareTOCStyleEntry[pagenumberformat=\MyLSgobblepagenumber,linefill=\hfil,pagenumberwidth=0pt]{section}{section}

% No running header and no page numbers.  The class (via scrlayer-scrpage) puts
% the song title in the page header (pages 2+) and a "page X of Y" line in the
% footer; \clearpairofpagestyles wipes every head/foot slot of the scrheadings
% pagestyle (and its plain variant) in one documented command.
\clearpairofpagestyles

% Chords print in every build except the lyrics view, which strips the ^{C}
% chords to leave the words alone (the only thing distinguishing it from the
% default build -- see the view-selection block above).
\ifMyLSlyrics
  \setleadsheets{ print-chords = false }
\else
  \setleadsheets{ print-chords = true  }
\fi

% ---------------------------------------------------------------------------
% Remarks  ("Remarks" block at the bottom of the last page)
% ---------------------------------------------------------------------------
% A `remarks' environment, written AFTER \end{song} (outside the song env),
% appends a remarks block to the bottom of the song's last page:
%
%   \end{song}
%   \begin{remarks}
%     Any free-text prose about the song.
%   \end{remarks}
%
% It prints a header "Remarks", then the environment's own free-text body.  A
% bare \begin{remarks}\end{remarks} just prints the "Remarks" header.  The block
% reads NOTHING from the song -- it is pure free text -- so it has no coupling to
% the preceding song and no song-id plumbing (earlier revisions surfaced the
% song's title/tempo/`remarks' property here, which needed a captured song id;
% all three are gone).
%
% WHY OUTSIDE THE SONG ENV.  Inside \begin{song}...\end{song} leadsheets makes
% ^ _ | : active (chord / barline shorthands) and applies the bold "song" body
% format -- both hostile to prose.  Outside, catcodes and formatting are normal,
% so the body is ordinary text.  A songbook still gets the block:
% \includeleadsheet rewrites the included file's \end{document}->\endinput
% (leadsheets.library.external.code.tex), so everything between \begin{document}
% and \end{document} -- including a post-\end{song} remarks block -- is pulled in.
%
% POSITIONING.  The block is NOT pushed to the page bottom.  An earlier design
% put \vfill at the top to drop it to the foot of the last page, but that made
% the block's position depend on how full the page was: on a song that fills the
% page it sat snugly under the last section, but on a short song the \vfill blew
% open a large gap and left the block marooned in mid-page whitespace.  Instead a
% fixed, slightly-rubber \addvspace{\MyLSremarksskip} separates it from the song
% body, so it always sits just below the last section; if it does not fit it
% flows to the TOP of the next page (the leading \addvspace is discarded there),
% not stranded at the foot.  The body is set in \MyLSremarksbodyfont (\small by
% default) to subordinate it to the song.  Restyle/space via the \MyLSremarks*
% knobs (\setlength\MyLSremarksskip{...} for the gap).
%
% VIEW FILTERING.  An optional comma-list of view names restricts the block to
% those views: \begin{remarks}[chords] prints only in the chords view,
% \begin{remarks}[chords,full] in those two.  A bare \begin{remarks} (empty list)
% prints in EVERY view.  The `debug' view is exempt -- it always shows every
% remarks block, since it exists to proof everything on one sheet.  This is the
% xparse `+b' body-swallow the chords/lyrics verse types use: the body is captured
% as an argument and either typeset or silently discarded.  expl3 is used only for
% the (exact-item) comma-list membership test; the author's prose body keeps its
% document catcodes (it is read where \begin{remarks} appears, not where the
% environment is defined).
\newcommand\MyLSremarkslabel{Remarks}
\newcommand\MyLSremarksheadfont{\large\sffamily\bfseries}
\newcommand\MyLSremarksrule{\par\hrule\vskip4pt\par}
% Gap above the block (slightly rubber so a near-full page can absorb a little),
% and the body font (smaller than the song body to subordinate it).
\newlength\MyLSremarksskip
\setlength\MyLSremarksskip{\bigskipamount}
\newcommand\MyLSremarksbodyfont{\small}
\ExplSyntaxOn
\prg_generate_conditional_variant:Nnn \clist_if_in:Nn { Ne } { TF }
\clist_new:N \l__myls_remarks_views_clist
% \__myls_remarks_show:nTF {<view-list>} -- print in the current \View?
\prg_new_protected_conditional:Npnn \__myls_remarks_show:n #1 { TF }
  {
    \tl_if_empty:nTF {#1}
      { \prg_return_true: }
      {
        \str_if_eq:eeTF { \View } { debug }
          { \prg_return_true: }
          {
            \clist_set:Nn \l__myls_remarks_views_clist {#1}
            \clist_if_in:NeTF \l__myls_remarks_views_clist { \View }
              { \prg_return_true: }
              { \prg_return_false: }
          }
      }
  }
\NewDocumentEnvironment{remarks}{ O{} +b }
  {
    \__myls_remarks_show:nTF {#1}
      {
        \par \addvspace{\MyLSremarksskip}
        \setlength \parindent {0pt}
        \MyLSremarksrule
        { \MyLSremarksheadfont \MyLSremarkslabel \par }
        { \MyLSremarksbodyfont #2 \par }
      }
      { }
  }
  { }
\ExplSyntaxOff

% ---------------------------------------------------------------------------
% Even-page / odd-start padding for two-page (spread) digital viewing
% ---------------------------------------------------------------------------
% These PDFs are read on screen in two-page (spread) mode, where parity matters:
% one page of the wrong parity shoves every later spread off by one.  Two opt-in
% tools, both built on the same "ship a blank page" idiom (\MyLSblankpage):
% \null forces the otherwise-empty page to actually ship, \thispagestyle{empty}
% keeps it free of any head/foot (matching the no-numbers layout above).
%
% Parity note (shared by both): after a \clearpage the `page' counter holds the
% number the NEXT shipped page will get, i.e. (pages-shipped + 1).  So an odd
% counter means an even number of pages has shipped, and vice versa.  Both tools
% test this counter and conditionally append ONE blank -- and crucially measure
% BEFORE adding it, so the decision is identical on every run (no oscillation
% under latexmk; a \pageref{LastPage}-style test would instead count the blank it
% just added and flip parity each rebuild).
\newcommand\MyLSblankpage{\null\thispagestyle{empty}\clearpage}

% --- \ForceEvenPages: pad a STANDALONE song to an even total ------------------
% A song opts in by putting \ForceEvenPages in its preamble; nothing happens
% otherwise.  Fires once at \AtEndDocument: even counter => odd content => append
% a blank to make the total even.  (No use in a songbook -- \AtEndDocument fires
% once for the whole book, not per included song; use \clearoddpage there.)
\newif\ifMyLSforceeven
\newcommand\ForceEvenPages{\MyLSforceeventrue}
\AtEndDocument{%
  \ifMyLSforceeven
    \clearpage
    \ifodd\value{page}\else \MyLSblankpage \fi
  \fi
}

% --- \clearoddpage: start the NEXT block on an odd page -----------------------
% For songbooks: use it in place of \newpage before each \includeleadsheet (also
% before the first, which pads the TOC to even so song 1 lands on an odd page).
% Each later song then begins on an odd page, and blanks appear only where a song
% ended on an odd page -- a naturally even-length song gets none.  This is what
% KOMA's \cleardoubleoddpage would do, but that gates its blank behind
% \if@twoside (scrartcl.cls), and this class is single-sided; going twoside would
% swap margins and restore headers, so we pad explicitly instead.
%
% The `phone' view degrades this to a plain \clearpage (no odd-page padding):
% page parity is meaningless on the tall single-page-per-song phone layout, and
% the padding would only insert very long blank pages between songs.  Because
% \bookinclude calls \clearoddpage, this one guard covers the whole songbook.
\newcommand\clearoddpage{%
  \clearpage
  \ifMyLSphone\else
    \ifodd\value{page}\else \MyLSblankpage \fi
  \fi
}

% ---------------------------------------------------------------------------
% Songbook "back to contents" link  (songbook-only; no effect standalone)
% ---------------------------------------------------------------------------
% In a songbook each song can carry a hyperlink back to the table of contents,
% in the bottom-right corner of its LAST page -- but ONLY when it fits in the
% leftover space, so it never forces an extra page (a chock-full last page simply
% gets no link).  This is purely a songbook concern: it lives in the include
% wrapper \bookinclude and is never seen by a song compiled on its own, so an
% individual .song needs no change and cannot be broken by this feature.
%
% Requires hyperref, which the songbook loads; the \AtBeginDocument fallback
% below keeps things harmless if it is absent (link degrades to plain text).
% Put \MyLStoctarget once, just before \tableofcontents, as the jump destination.
\AtBeginDocument{%
  \providecommand\hyperlink[2]{#2}%
  \providecommand\hypertarget[2]{#2}%
}
\newcommand\MyLStocname{MyLStoc}
\newcommand\MyLStoctarget{\hypertarget{\MyLStocname}{}}
% appearance -- redefine in the songbook preamble to restyle.  The link size is a
% separate knob so the `phone' view can enlarge it (the rest of the views keep
% the discreet \footnotesize) without the songbook having to override the whole
% link text; the fit-test below measures the actual box, so a larger link is
% accounted for automatically.
\ifMyLSphone
  \newcommand\MyLStoclinksize{\large}
\else
  \newcommand\MyLStoclinksize{\footnotesize}
\fi
\providecommand\MyLStoclinktext{\textsf{\MyLStoclinksize$\hookleftarrow$\,Contents}}
% safety margin kept clear below the last line before the link is allowed to fit
\newcommand\MyLStocgap{2\baselineskip}

% Emit the link at the bottom-right IFF the space left on the current page can
% hold it (link height + gap); otherwise nothing.  \penalty0 after \par makes the
% page builder count the last line so \pagetotal is current; \pagegoal reads
% \maxdimen on a still-empty page, treated as a full \textheight of room.  The
% slack is measured BEFORE the box is added and we only ever append strictly less
% than that slack, so the page can never overfill.  \vfill drops the box to the
% bottom; the next \clearpage (from the following \bookinclude, or \end{document})
% flushes it.  Scratch registers \dimen0/\box0 are used because `@' is not a
% catcode letter in this package (see the \MyLS... naming throughout).
\newcommand\MyLStochint{%
  \par\penalty0
  \begingroup
    \setbox0=\hbox{\hyperlink{\MyLStocname}{\MyLStoclinktext}}%
    \dimen0=\pagegoal
    \ifdim\dimen0=\maxdimen \dimen0=\textheight \fi
    \advance\dimen0 -\pagetotal
    \ifdim\dimen0>\dimexpr\ht0+\dp0+\MyLStocgap\relax
      \vfill\nointerlineskip\hbox to\hsize{\hfill\box0}%
    \fi
  \endgroup
}

% --- \MyLSaddsongdir: make a wrapper's shared-body \input cwd-proof -----------
% A wrapper .song pulls in its shared body with a bare \input{Song--input.song},
% which TeX resolves relative to the MAIN job's directory (plus TEXINPUTS), NOT
% relative to the wrapper file.  Compiled on its own the cwd IS the song's folder,
% so the sibling body is found.  But \bookinclude'd into a songbook whose .song
% sits in a PARENT directory (e.g. \bookinclude{song-files/Song.song}), the bare
% body name no longer resolves: either "File not found", or -- worse and silent --
% a stale same-named body elsewhere on TEXINPUTS gets picked up instead.
% Fix: parse the included song's own directory out of the \bookinclude argument
% and prepend it to \input@path, so the nested \input also searches that folder.
% (@ is not a catcode letter in this package -- see line ~52 -- so wrap in
% \makeatletter, as elsewhere.)
\makeatletter
\newcommand\MyLSaddsongdir[1]{%
  \filename@parse{#1}%
  \ifx\filename@area\@empty\else
    \@ifundefined{input@path}{\def\input@path{}}{}%
    \edef\input@path{{\filename@area}\input@path}%
  \fi
}
\makeatother

% Songbook include wrapper, replacing the bare \clearoddpage\includeleadsheet:
% start this song on an odd page (padding the previous song / the TOC), pull it
% in, then drop the fit-tested back-to-contents link on its last page.  A song
% that should NOT get a link can still use \clearoddpage\includeleadsheet directly
% (but loses the \MyLSaddsongdir fix, so a hand-included shared-body wrapper would
% need \MyLSaddsongdir before \includeleadsheet, both in a group).  The \begingroup
% scopes \input@path to this one song so it reverts before the next include; the
% include's lasting effects (TOC/bookmark writes, counters) are global, so the
% group does not lose them.
\newcommand\bookinclude[1]{%
  \clearoddpage
  \begingroup
    \MyLSaddsongdir{#1}%
    \includeleadsheet{#1}%
  \endgroup
  \MyLStochint
}

% ---------------------------------------------------------------------------
% Debug aid: make overfull \hbox lines visible in the PDF
% ---------------------------------------------------------------------------
% TeX normally only *reports* an overfull \hbox in the log (a line whose content
% runs past the right margin).  Setting the primitive \overfullrule to a nonzero
% width makes it also *draw* a solid black rule in the margin beside each such
% line in the output -- the same mechanism the `draft' class option turns on
% (draft => 5pt, final => 0pt).  Kept off by default so finished sheets stay
% clean; a song opts in by putting \MyLSshowoverfull in its preamble.  The
% optional argument overrides the rule width, e.g. \MyLSshowoverfull[10pt].
\newcommand\MyLSshowoverfull[1][5pt]{\setlength\overfullrule{#1}}
